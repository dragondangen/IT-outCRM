@using IT_outCRM.Blazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime

<div class="sidebar-root @(isCollapsed ? "collapsed" : "")" id="sidebar">
    <div class="sidebar-header">
        @if (!isCollapsed)
        {
            <NavLink href="/" class="sidebar-brand" Match="NavLinkMatch.All">
                <span class="sidebar-logo">IT-outCRM</span>
            </NavLink>
        }
        <button class="sidebar-btn" @onclick="HandleToggleClick">
            <i class="bi @GetToggleIcon()"></i>
        </button>
    </div>

    <div class="sidebar-divider"></div>

    <nav class="sidebar-nav">
        <AuthorizeView>
            <Authorized>
                <NavLink class="nav-link sidebar-link" href="dashboard" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </NavLink>

                @if (context.User.IsInRole("Executor"))
                {
                    <NavLink class="nav-link sidebar-link" href="orders" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-box-seam-fill"></i> <span>Заказы</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="executor/my-orders" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-list-check"></i> <span>Мои заказы</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="my-deals" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-cash-stack"></i> <span>Мои сделки</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="my-services" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-briefcase-fill"></i> <span>Мои услуги</span>
                    </NavLink>
                }

                @if (!context.User.IsInRole("Admin") && !context.User.IsInRole("Manager") && !context.User.IsInRole("Executor"))
                {
                    <NavLink class="nav-link sidebar-link" href="my-orders" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-box-seam"></i> <span>Мои заказы</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="my-deals" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-cash-stack"></i> <span>Мои сделки</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="services-catalog" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-shop"></i> <span>Каталог услуг</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="orders/create" Match="NavLinkMatch.All" @onclick="HandleNavLinkClick">
                        <i class="bi bi-plus-circle"></i> <span>Создать заказ</span>
                    </NavLink>
                }

                @if (context.User.IsInRole("Admin") || context.User.IsInRole("Manager"))
                {
                    <NavLink class="nav-link sidebar-link" href="orders" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-box-seam-fill"></i> <span>Все заказы</span>
                    </NavLink>

                    <div class="sidebar-divider"></div>
                    <div class="sidebar-section">
                        <i class="bi bi-star-fill"></i> <span>СПРАВОЧНИКИ</span>
                    </div>

                    <NavLink class="nav-link sidebar-link" href="customers" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-people-fill"></i> <span>Клиенты</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="executors" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-person-gear"></i> <span>Исполнители</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="companies" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-building"></i> <span>Компании</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="contactpersons" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-person-rolodex"></i> <span>Контактные лица</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="order-statuses" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-card-checklist"></i> <span>Статусы заказов</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="all-services" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-briefcase"></i> <span>Все услуги</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="my-deals" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-cash-stack"></i> <span>Все сделки</span>
                    </NavLink>
                    <NavLink class="nav-link sidebar-link" href="reports" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-graph-up"></i> <span>Аналитика</span>
                    </NavLink>
                }

                @if (context.User.IsInRole("Admin"))
                {
                    <div class="sidebar-divider"></div>
                    <div class="sidebar-section">
                        <i class="bi bi-shield-lock-fill"></i> <span>АДМИНИСТРИРОВАНИЕ</span>
                    </div>
                    <NavLink class="nav-link sidebar-link" href="accounts" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                        <i class="bi bi-people-fill"></i> <span>Пользователи</span>
                    </NavLink>
                }

                <div class="sidebar-divider"></div>

                <NavLink class="nav-link sidebar-link" href="profile" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                    <i class="bi bi-person-circle"></i> <span>Профиль</span>
                </NavLink>
            </Authorized>
            <NotAuthorized>
                <NavLink class="nav-link sidebar-link" href="login" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                    <i class="bi bi-box-arrow-in-right"></i> <span>Войти</span>
                </NavLink>
                <NavLink class="nav-link sidebar-link" href="register" Match="NavLinkMatch.Prefix" @onclick="HandleNavLinkClick">
                    <i class="bi bi-person-plus-fill"></i> <span>Регистрация</span>
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </nav>

    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <div class="sidebar-user">
                    <div class="sidebar-user-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <div class="sidebar-user-text">
                        <div class="sidebar-user-name">@context.User.Identity?.Name</div>
                        <div class="sidebar-user-role">@GetUserRole(context.User)</div>
                    </div>
                </div>
                <button type="button" class="nav-link sidebar-link sidebar-logout" @onclick="HandleLogoutClick">
                    <i class="bi bi-box-arrow-right"></i> <span>Выйти</span>
                </button>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    private bool isCollapsed = false;
    private double sidebarWidth = 250;
    private DotNetObjectReference<NavMenu>? _dotNetRef;

    [Parameter]
    public bool IsMobileMenuOpen { get; set; }

    [Parameter]
    public EventCallback OnCloseRequested { get; set; }

    [Parameter]
    public EventCallback<bool> OnCollapseChanged { get; set; }

    protected override void OnInitialized()
    {
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (IsMobileMenuOpen)
        {
            OnCloseRequested.InvokeAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await UpdateSidebarWidthFromStorage();
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("window.initSidebarBlazorInterop", _dotNetRef);
            }
            catch (JSException) { }
        }
    }

    private async Task UpdateSidebarWidthFromStorage()
    {
        try
        {
            var widthStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "sidebarWidth");
            if (!string.IsNullOrEmpty(widthStr))
            {
                var val = widthStr.Replace("px", "").Trim();
                if (double.TryParse(val, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var w) && w >= 200 && w <= 500)
                {
                    sidebarWidth = w;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch { }
    }

    private string GetToggleIcon()
    {
        if (IsMobileMenuOpen) return "bi-x-lg";
        return isCollapsed ? "bi-list" : "bi-chevron-left";
    }

    private async Task HandleToggleClick()
    {
        if (IsMobileMenuOpen)
        {
            await OnCloseRequested.InvokeAsync();
            return;
        }
        isCollapsed = !isCollapsed;
        if (!isCollapsed) await UpdateSidebarWidthFromStorage();
        await OnCollapseChanged.InvokeAsync(isCollapsed);
        StateHasChanged();
    }

    private async Task HandleNavLinkClick()
    {
        if (IsMobileMenuOpen)
            await OnCloseRequested.InvokeAsync();
    }

    [JSInvokable]
    public async Task HandleWindowResize()
    {
        try
        {
            var w = await JSRuntime.InvokeAsync<int>("eval", "window.innerWidth");
            if (w <= 768 && IsMobileMenuOpen)
                await OnCloseRequested.InvokeAsync();
        }
        catch { }
    }

    [JSInvokable]
    public async Task OnSidebarWidthChanged()
    {
        await UpdateSidebarWidthFromStorage();
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleLogoutClick()
    {
        try
        {
            await AuthService.LogoutAsync();
        }
        catch { }

        try
        {
            Navigation.NavigateTo("/login", forceLoad: true);
        }
        catch { }
    }

    private string GetUserRole(System.Security.Claims.ClaimsPrincipal user)
    {
        if (user.IsInRole("Admin")) return "Админ";
        if (user.IsInRole("Manager")) return "Менеджер";
        if (user.IsInRole("Executor")) return "Исполнитель";
        return "Клиент";
    }

    public async ValueTask DisposeAsync()
    {
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        try { await JSRuntime.InvokeVoidAsync("window.disposeSidebarBlazorInterop"); } catch { }
        _dotNetRef?.Dispose();
    }
}

<style>
    /* =============================================
       SIDEBAR — написано с нуля, без блюра
       ============================================= */
    .sidebar-root {
        background: linear-gradient(180deg, #0d1117 0%, #161b22 50%, #0d1117 100%);
        width: 250px;
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: width 0.25s ease;
        position: relative;
    }

    .sidebar-root.collapsed {
        width: 70px !important;
    }

    /* Header */
    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1rem;
        min-height: 60px;
    }

    .sidebar-brand {
        text-decoration: none;
        flex: 1;
        min-width: 0;
    }

    .sidebar-logo {
        font-size: 1.5rem;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.5px;
        white-space: nowrap;
    }

    /* Toggle Button — КРУПНАЯ И ВИДИМАЯ */
    .sidebar-btn {
        width: 42px;
        height: 42px;
        min-width: 42px;
        min-height: 42px;
        background: #21262d;
        border: 2px solid #30363d;
        border-radius: 10px;
        color: #e6edf3;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        padding: 0;
        flex-shrink: 0;
    }

    .sidebar-btn:hover {
        background: #30363d;
        border-color: #58a6ff;
        color: #ffffff;
    }

    .sidebar-btn:active {
        background: #388bfd;
        border-color: #388bfd;
    }

    .sidebar-btn i {
        font-size: 1.4rem;
        line-height: 1;
    }

    /* Collapsed — кнопка по центру */
    .sidebar-root.collapsed .sidebar-header {
        justify-content: center;
        padding: 1rem 0.5rem;
    }

    .sidebar-root.collapsed .sidebar-brand {
        display: none;
    }

    /* Divider */
    .sidebar-divider {
        height: 1px;
        background: #21262d;
        margin: 0.5rem 1rem;
    }

    .sidebar-root.collapsed .sidebar-divider {
        display: none;
    }

    /* Navigation */
    .sidebar-nav {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 0.25rem 0;
        scrollbar-width: none;
    }

    .sidebar-nav::-webkit-scrollbar {
        display: none;
    }

    .sidebar-link {
        color: #8b949e !important;
        padding: 0.8rem 1.25rem !important;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: color 0.15s, background 0.15s, border-color 0.15s;
        white-space: nowrap;
    }

    .sidebar-link i {
        font-size: 1.15rem;
        width: 22px;
        text-align: center;
        flex-shrink: 0;
    }

    .sidebar-link:hover {
        color: #e6edf3 !important;
        background: rgba(255, 255, 255, 0.05);
        border-left-color: #30363d;
    }

    .sidebar-link.active {
        color: #ffffff !important;
        background: rgba(56, 139, 253, 0.15) !important;
        border-left-color: #58a6ff;
    }

    .sidebar-link.active i {
        color: #58a6ff;
    }

    /* Collapsed — иконки по центру */
    .sidebar-root.collapsed .sidebar-link {
        justify-content: center;
        padding: 0.8rem 0 !important;
    }

    .sidebar-root.collapsed .sidebar-link span,
    .sidebar-root.collapsed .sidebar-section {
        display: none;
    }

    /* Section Label */
    .sidebar-section {
        padding: 0.6rem 1.25rem 0.3rem;
        font-size: 0.7rem;
        font-weight: 700;
        color: #484f58;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .sidebar-section i {
        font-size: 0.6rem;
    }

    /* Footer */
    .sidebar-footer {
        margin-top: auto;
        border-top: 1px solid #21262d;
        padding-top: 0.5rem;
    }

    .sidebar-root.collapsed .sidebar-footer,
    .sidebar-root.collapsed .sidebar-user {
        display: none;
    }

    .sidebar-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        margin: 0.5rem 0.75rem;
        background: #161b22;
        border: 1px solid #21262d;
        border-radius: 10px;
    }

    .sidebar-user-icon {
        width: 40px;
        height: 40px;
        min-width: 40px;
        background: #21262d;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sidebar-user-icon i {
        font-size: 1.2rem;
        color: #58a6ff;
    }

    .sidebar-user-text {
        flex: 1;
        min-width: 0;
    }

    .sidebar-user-name {
        font-weight: 600;
        color: #e6edf3;
        font-size: 0.9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sidebar-user-role {
        font-size: 0.75rem;
        color: #484f58;
        font-weight: 500;
    }

    .sidebar-logout:hover {
        background: rgba(248, 81, 73, 0.1) !important;
        border-left-color: #f85149;
    }

    .sidebar-logout:hover i {
        color: #f85149 !important;
    }

    /* Мобильные переопределения */
    @@media (max-width: 768px) {
        .sidebar-root {
            width: 100% !important;
            height: 100%;
            overflow-y: auto;
        }

        .sidebar-root.collapsed {
            width: 100% !important;
        }

        .sidebar-root.collapsed .sidebar-link span,
        .sidebar-root.collapsed .sidebar-section,
        .sidebar-root.collapsed .sidebar-user,
        .sidebar-root.collapsed .sidebar-footer,
        .sidebar-root.collapsed .sidebar-divider,
        .sidebar-root.collapsed .sidebar-brand {
            display: flex !important;
        }

        .sidebar-root.collapsed .sidebar-link {
            justify-content: flex-start;
            padding: 0.8rem 1.25rem !important;
        }

        .sidebar-root.collapsed .sidebar-header {
            justify-content: space-between;
        }
    }
</style>
