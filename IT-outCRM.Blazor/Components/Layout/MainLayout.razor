@inherits LayoutComponentBase
@using IT_outCRM.Blazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<div class="page">
    @if (isMobileMenuOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseMobileMenu"></div>
    }

    <div class="sidebar @(isMobileMenuOpen ? "mobile-open" : "") @(isSidebarCollapsed ? "collapsed" : "")">
        <NavMenu @ref="navMenu"
                 IsMobileMenuOpen="@isMobileMenuOpen"
                 OnCloseRequested="@(() => { isMobileMenuOpen = false; StateHasChanged(); })"
                 OnCollapseChanged="@((collapsed) => { isSidebarCollapsed = collapsed; StateHasChanged(); })" />
    </div>

    <main>
        @if (!isMobileMenuOpen)
        {
            <button class="mobile-fab" @onclick="ToggleMobileMenu" aria-label="Меню">
                <i class="bi bi-list"></i>
            </button>
        }
        <article class="content">
            <ErrorBoundary @key="@Navigation.Uri">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="container mt-5">
                        <div class="alert alert-danger" role="alert">
                            <h4 class="alert-heading">
                                <i class="bi bi-exclamation-triangle-fill"></i> Произошла ошибка!
                            </h4>
                            <p><strong>Сообщение:</strong> @ex.Message</p>
                            @if (ex.StackTrace != null)
                            {
                                <details class="mt-3">
                                    <summary>Детали ошибки</summary>
                                    <pre class="mt-2 small">@ex.StackTrace</pre>
                                </details>
                            }
                            <hr>
                            <div class="d-flex gap-2">
                                <button class="btn btn-primary" @onclick="() => Navigation.NavigateTo(Navigation.Uri, forceLoad: true)">
                                    <i class="bi bi-arrow-clockwise"></i> Перезагрузить страницу
                                </button>
                                <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo("/")'>
                                    <i class="bi bi-house"></i> На главную
                                </button>
                            </div>
                        </div>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private NavMenu? navMenu;
    private bool isMobileMenuOpen = false;
    private bool isSidebarCollapsed = false;

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        isMobileMenuOpen = false;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Force authentication state check after first render
            if (AuthStateProvider is CustomAuthenticationStateProvider customProvider)
            {
                customProvider.NotifyAuthenticationStateChanged();
            }
        }
    }
}