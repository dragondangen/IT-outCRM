@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">IT-outCRM - Система управления</a>
        </div>

        <article class="content px-4">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="alert alert-danger" role="alert">
                        <h4 class="alert-heading">Произошла ошибка!</h4>
                        <p>@ex.Message</p>
                        <hr>
                        <p class="mb-0">
                            <button class="btn btn-primary" @onclick="() => Navigation.NavigateTo(Navigation.Uri, forceLoad: true)">
                                Перезагрузить страницу
                            </button>
                        </p>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </article>
    </main>
</div>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;
}
