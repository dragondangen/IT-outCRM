@page "/test-auth"
@inject IJSRuntime JS
@rendermode InteractiveServer

<h3>Тестирование авторизации (Прямой запрос)</h3>

<p>Эта страница пытается сделать запрос к API напрямую из браузера, чтобы увидеть заголовки и ответ.</p>

<button class="btn btn-primary" @onclick="TestDirectApiCall">Выполнить тест</button>

<div class="mt-3">
    <textarea class="form-control" rows="10" @bind="logOutput"></textarea>
</div>

<script>
    window.testApi = async (url) => {
        const token = localStorage.getItem('authToken'); // Берем сырой токен
        console.log("Testing with token:", token);
        
        try {
            const response = await fetch(url + '/api/companies', {
                method: 'GET',
                headers: {
                    'Authorization': 'Bearer ' + token,
                    'Content-Type': 'application/json'
                }
            });
            
            const status = response.status;
            const text = await response.text();
            const headers = {};
            response.headers.forEach((value, key) => headers[key] = value);
            
            return JSON.stringify({ status, headers, body: text }, null, 2);
        } catch (e) {
            return "Error: " + e.message;
        }
    }
</script>

@code {
    private string logOutput = "Нажмите кнопку для теста...";

    private async Task TestDirectApiCall()
    {
        logOutput = "Отправка запроса...";
        // Используем URL API напрямую
        var apiUrl = "http://localhost:5295"; 
        
        try
        {
            var result = await JS.InvokeAsync<string>("testApi", apiUrl);
            logOutput = result;
        }
        catch (Exception ex)
        {
            logOutput = $"JS Error: {ex.Message}";
        }
    }
}


