@page "/reports"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Manager")]
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Отчеты - IT-outCRM</PageTitle>

<div class="reports-container">
    <div class="page-header">
        <h2>📊 Отчеты и аналитика</h2>
        <p class="text-muted">Статистика и аналитические отчеты по работе системы</p>
    </div>

    <div class="coming-soon">
        <div class="icon-box">
            <i class="bi bi-graph-up-arrow"></i>
        </div>
        <h3>Раздел в разработке</h3>
        <p class="lead">Скоро здесь появятся:</p>
        
        <div class="features-grid">
            <div class="feature-card">
                <i class="bi bi-pie-chart"></i>
                <h5>Графики и диаграммы</h5>
                <p>Визуализация данных о заказах, клиентах и продажах</p>
            </div>

            <div class="feature-card">
                <i class="bi bi-file-earmark-bar-graph"></i>
                <h5>Отчеты по периодам</h5>
                <p>Статистика за день, неделю, месяц и год</p>
            </div>

            <div class="feature-card">
                <i class="bi bi-cash-stack"></i>
                <h5>Финансовая аналитика</h5>
                <p>Доходы, расходы и прибыль</p>
            </div>

            <div class="feature-card">
                <i class="bi bi-people"></i>
                <h5>Отчеты по клиентам</h5>
                <p>Активность клиентов и история заказов</p>
            </div>

            <div class="feature-card">
                <i class="bi bi-person-workspace"></i>
                <h5>Производительность исполнителей</h5>
                <p>Статистика выполнения заказов</p>
            </div>

            <div class="feature-card">
                <i class="bi bi-file-earmark-pdf"></i>
                <h5>Экспорт отчетов</h5>
                <p>Выгрузка в PDF, Excel и другие форматы</p>
            </div>
        </div>

        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle"></i> 
            <strong>Обратите внимание:</strong> Функциональность отчетов будет доступна в следующей версии системы. 
            Пока вы можете использовать Dashboard для просмотра основной статистики.
        </div>

        <div class="action-buttons">
            <button class="btn btn-primary btn-lg" @onclick="GoToDashboard">
                <i class="bi bi-speedometer2"></i> Перейти к Dashboard
            </button>
            <button class="btn btn-outline-secondary btn-lg" @onclick="GoBack">
                <i class="bi bi-arrow-left"></i> Вернуться назад
            </button>
        </div>
    </div>
</div>

<style>
    .reports-container {
        padding: 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 40px;
        text-align: center;
    }

    .page-header h2 {
        font-size: 2.5rem;
        color: #333;
        margin-bottom: 10px;
    }

    .coming-soon {
        background: white;
        border-radius: 20px;
        padding: 60px 40px;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .icon-box {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        animation: pulse 2s ease-in-out infinite;
    }

    .icon-box i {
        font-size: 4rem;
        color: white;
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    .coming-soon h3 {
        font-size: 2rem;
        color: #333;
        margin-bottom: 15px;
    }

    .coming-soon .lead {
        font-size: 1.2rem;
        color: #666;
        margin-bottom: 40px;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .feature-card {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 30px;
        transition: all 0.3s ease;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .feature-card i {
        font-size: 2.5rem;
        color: #667eea;
        margin-bottom: 15px;
    }

    .feature-card h5 {
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
    }

    .feature-card p {
        color: #666;
        margin: 0;
        font-size: 0.95rem;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .action-buttons .btn {
        min-width: 200px;
    }
</style>

@code {
    private void GoToDashboard()
    {
        Navigation.NavigateTo("/dashboard");
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }
}
