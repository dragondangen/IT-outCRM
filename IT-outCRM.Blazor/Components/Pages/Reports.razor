@page "/reports"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using IT_outCRM.Blazor.Models
@using IT_outCRM.Blazor.Services
@attribute [Authorize(Roles = "Admin,Manager")]
@inject IAnalyticsService AnalyticsService
@inject ITokenStorage TokenStorage
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Отчёты и аналитика - IT-outCRM</PageTitle>

<div class="reports-page">
    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Загрузка аналитики...</p>
        </div>
    }
    else if (data == null)
    {
        <div class="error-state">
            <i class="bi bi-exclamation-triangle"></i>
            <h4>Не удалось загрузить данные</h4>
            <button class="btn btn-primary" @onclick="LoadData">Попробовать снова</button>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="reports-header">
            <div class="reports-header-content">
                <h2><i class="bi bi-graph-up"></i> Отчёты и аналитика</h2>
                <p>Детальная статистика по работе CRM-системы</p>
            </div>
            <div class="reports-header-actions">
                <select class="form-select" @bind="selectedTab">
                    <option value="overview">Обзор</option>
                    <option value="revenue">Финансы</option>
                    <option value="orders">Заказы и сделки</option>
                    <option value="customers">Клиенты</option>
                    <option value="executors">Исполнители</option>
                    <option value="services">Услуги</option>
                </select>
            </div>
        </div>

        <!-- Tabs -->
        <div class="reports-tabs">
            <button class="tab-btn @(selectedTab == "overview" ? "active" : "")" @onclick='() => selectedTab = "overview"'>
                <i class="bi bi-speedometer2"></i> Обзор
            </button>
            <button class="tab-btn @(selectedTab == "revenue" ? "active" : "")" @onclick='() => selectedTab = "revenue"'>
                <i class="bi bi-cash-stack"></i> Финансы
            </button>
            <button class="tab-btn @(selectedTab == "orders" ? "active" : "")" @onclick='() => selectedTab = "orders"'>
                <i class="bi bi-box-seam"></i> Заказы и сделки
            </button>
            <button class="tab-btn @(selectedTab == "customers" ? "active" : "")" @onclick='() => selectedTab = "customers"'>
                <i class="bi bi-people"></i> Клиенты
            </button>
            <button class="tab-btn @(selectedTab == "executors" ? "active" : "")" @onclick='() => selectedTab = "executors"'>
                <i class="bi bi-person-workspace"></i> Исполнители
            </button>
            <button class="tab-btn @(selectedTab == "services" ? "active" : "")" @onclick='() => selectedTab = "services"'>
                <i class="bi bi-briefcase"></i> Услуги
            </button>
        </div>

        <!-- Content -->
        @if (selectedTab == "overview") { @RenderOverview() }
        else if (selectedTab == "revenue") { @RenderRevenue() }
        else if (selectedTab == "orders") { @RenderOrders() }
        else if (selectedTab == "customers") { @RenderCustomers() }
        else if (selectedTab == "executors") { @RenderExecutors() }
        else if (selectedTab == "services") { @RenderServices() }
    }
</div>

@code {
    private DashboardAnalyticsModel? data;
    private bool isLoading = true;
    private string selectedTab = "overview";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Task.Delay(300);

        string? token = null;
        for (int i = 0; i < 3; i++)
        {
            token = await TokenStorage.GetTokenAsync();
            if (!string.IsNullOrEmpty(token)) break;
            await Task.Delay(500);
        }

        if (string.IsNullOrEmpty(token))
        {
            try { Navigation.NavigateTo("/login", forceLoad: true); }
            catch { }
            return;
        }

        AnalyticsService.SetToken(token);
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            data = await AnalyticsService.GetDashboardAnalyticsAsync();
        }
        catch { data = null; }
        isLoading = false;
    }

    private RenderFragment RenderOverview() => __builder =>
    {
        var o = data!.Overview;
        <div class="section-grid-4">
            @RenderStatCard("Заказы", o.TotalOrders.ToString(), "bi-box-seam", "#3498db", $"Активных: {o.ActiveOrders}")
            @RenderStatCard("Сделки", o.TotalDeals.ToString(), "bi-cash-stack", "#6f42c1", $"Активных: {o.ActiveDeals}")
            @RenderStatCard("Клиенты", o.TotalCustomers.ToString(), "bi-people", "#27ae60", $"Аккаунтов: {o.TotalAccounts}")
            @RenderStatCard("Выручка", FormatMoney(o.TotalRevenue), "bi-wallet2", "#e67e22", $"Этот месяц: {FormatMoney(o.RevenueThisMonth)}")
        </div>

        <div class="section-grid-3">
            @RenderStatCard("Завершено заказов", o.CompletedOrders.ToString(), "bi-check-circle", "#27ae60", $"Отменено: {o.CancelledOrders}")
            @RenderStatCard("Завершено сделок", o.CompletedDeals.ToString(), "bi-trophy", "#f39c12", $"Средний чек: {FormatMoney(o.AverageDealValue)}")
            @RenderStatCard("Средний рейтинг", $"{o.AverageExecutorRating:0.0} / 5", "bi-star-fill", "#f1c40f", $"Исполнителей: {o.TotalExecutors}")
        </div>

        <!-- Conversion Funnel -->
        <div class="analytics-card">
            <h4><i class="bi bi-funnel"></i> Воронка конверсии</h4>
            <div class="funnel-container">
                @{ var funnel = data!.ConversionFunnel; var maxVal = Math.Max(funnel.PublishedOrders, 1); }
                @RenderFunnelStep("Опубликовано", funnel.PublishedOrders, maxVal, "#3498db")
                @RenderFunnelStep("В работе", funnel.OrdersInProgress, maxVal, "#f39c12")
                @RenderFunnelStep("На проверке", funnel.OrdersOnReview, maxVal, "#9b59b6")
                @RenderFunnelStep("Завершено", funnel.CompletedOrders, maxVal, "#27ae60")
                <div class="funnel-metrics">
                    <div class="funnel-metric">
                        <span class="metric-value">@funnel.OrderCompletionRate%</span>
                        <span class="metric-label">Завершение заказов</span>
                    </div>
                    <div class="funnel-metric">
                        <span class="metric-value">@funnel.DealConversionRate%</span>
                        <span class="metric-label">Конверсия сделок</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Distribution -->
        <div class="section-grid-2">
            <div class="analytics-card">
                <h4><i class="bi bi-pie-chart"></i> Заказы по статусам</h4>
                @foreach (var s in data!.OrdersByStatus)
                {
                    <div class="bar-item">
                        <div class="bar-header">
                            <span class="bar-label">@s.StatusName</span>
                            <span class="bar-value">@s.Count (@s.Percentage%)</span>
                        </div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width: @s.Percentage%; background: @s.Color;"></div>
                        </div>
                    </div>
                }
                @if (!data.OrdersByStatus.Any())
                {
                    <p class="text-muted text-center">Нет данных</p>
                }
            </div>
            <div class="analytics-card">
                <h4><i class="bi bi-pie-chart-fill"></i> Сделки по статусам</h4>
                @foreach (var s in data!.DealsByStatus)
                {
                    <div class="bar-item">
                        <div class="bar-header">
                            <span class="bar-label">@s.StatusName</span>
                            <span class="bar-value">@s.Count (@s.Percentage%)</span>
                        </div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width: @s.Percentage%; background: @s.Color;"></div>
                        </div>
                    </div>
                }
                @if (!data.DealsByStatus.Any())
                {
                    <p class="text-muted text-center">Нет данных</p>
                }
            </div>
        </div>
    };

    private RenderFragment RenderRevenue() => __builder =>
    {
        var rev = data!.Revenue;
        <div class="section-grid-4">
            @RenderStatCard("Общая выручка", FormatMoney(rev.TotalRevenue), "bi-wallet2", "#27ae60", "За всё время")
            @RenderStatCard("Этот месяц", FormatMoney(rev.RevenueThisMonth), "bi-calendar-check", "#3498db", rev.RevenueGrowthPercent >= 0 ? $"+{rev.RevenueGrowthPercent}%" : $"{rev.RevenueGrowthPercent}%")
            @RenderStatCard("Прошлый месяц", FormatMoney(rev.RevenueLastMonth), "bi-calendar-minus", "#95a5a6", "Для сравнения")
            @RenderStatCard("Средний заказ", FormatMoney(data.Overview.AverageOrderValue), "bi-calculator", "#e67e22", $"Средняя сделка: {FormatMoney(data.Overview.AverageDealValue)}")
        </div>

        <!-- Revenue sources -->
        <div class="analytics-card">
            <h4><i class="bi bi-cash"></i> Источники выручки</h4>
            <div class="revenue-sources">
                <div class="revenue-source">
                    <div class="source-info">
                        <span class="source-label">Заказы</span>
                        <span class="source-value">@FormatMoney(rev.RevenueFromOrders)</span>
                    </div>
                    <div class="bar-track large">
                        @{ var totalRev = rev.RevenueFromOrders + rev.RevenueFromDeals; var ordersPct = totalRev > 0 ? rev.RevenueFromOrders / totalRev * 100 : 0; }
                        <div class="bar-fill" style="width: @ordersPct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%; background: #3498db;"></div>
                    </div>
                </div>
                <div class="revenue-source">
                    <div class="source-info">
                        <span class="source-label">Сделки</span>
                        <span class="source-value">@FormatMoney(rev.RevenueFromDeals)</span>
                    </div>
                    <div class="bar-track large">
                        @{ var dealsPct = totalRev > 0 ? rev.RevenueFromDeals / totalRev * 100 : 0; }
                        <div class="bar-fill" style="width: @dealsPct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%; background: #6f42c1;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Monthly Revenue Chart -->
        <div class="analytics-card">
            <h4><i class="bi bi-bar-chart"></i> Выручка по месяцам</h4>
            @if (data.MonthlyRevenue.Any())
            {
                var maxRev = data.MonthlyRevenue.Max(m => m.TotalRevenue);
                <div class="chart-bars">
                    @foreach (var m in data.MonthlyRevenue)
                    {
                        var heightPct = maxRev > 0 ? (double)(m.TotalRevenue / maxRev) * 100 : 0;
                        <div class="chart-bar-group">
                            <div class="chart-bar-wrapper">
                                <div class="chart-bar" style="height: @heightPct.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%; background: linear-gradient(to top, #6f42c1, #9b59b6);"
                                     title="@FormatMoney(m.TotalRevenue)"></div>
                            </div>
                            <span class="chart-label">@m.Month</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center">Нет данных за указанный период</p>
            }
        </div>
    };

    private RenderFragment RenderOrders() => __builder =>
    {
        var o = data!.Overview;
        var funnel = data.ConversionFunnel;

        <div class="section-grid-4">
            @RenderStatCard("Всего заказов", o.TotalOrders.ToString(), "bi-box-seam", "#3498db", $"Средняя цена: {FormatMoney(o.AverageOrderValue)}")
            @RenderStatCard("Активные", o.ActiveOrders.ToString(), "bi-play-circle", "#f39c12", "В работе прямо сейчас")
            @RenderStatCard("Завершённые", o.CompletedOrders.ToString(), "bi-check-circle", "#27ae60", $"Конверсия: {funnel.OrderCompletionRate}%")
            @RenderStatCard("Всего сделок", o.TotalDeals.ToString(), "bi-cash-stack", "#6f42c1", $"Завершено: {o.CompletedDeals}")
        </div>

        <!-- Deals status breakdown -->
        <div class="analytics-card">
            <h4><i class="bi bi-list-check"></i> Детализация по статусам сделок</h4>
            <div class="status-cards-grid">
                @foreach (var s in data.DealsByStatus)
                {
                    <div class="status-detail-card" style="border-left: 4px solid @s.Color;">
                        <div class="status-detail-count">@s.Count</div>
                        <div class="status-detail-name">@s.StatusName</div>
                        <div class="status-detail-pct">@s.Percentage%</div>
                    </div>
                }
            </div>
        </div>

        <!-- Monthly chart -->
        <div class="analytics-card">
            <h4><i class="bi bi-bar-chart-line"></i> Динамика сделок по месяцам</h4>
            @if (data.MonthlyOrders.Any())
            {
                var maxCount = data.MonthlyOrders.Max(m => Math.Max(m.Created, Math.Max(m.Completed, m.Cancelled)));
                maxCount = Math.Max(maxCount, 1);
                <div class="monthly-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Месяц</th>
                                <th>Создано</th>
                                <th>Завершено</th>
                                <th>Отменено</th>
                                <th>Динамика</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in data.MonthlyOrders.TakeLast(6))
                            {
                                <tr>
                                    <td><strong>@m.Month @m.Year</strong></td>
                                    <td><span class="badge bg-primary">@m.Created</span></td>
                                    <td><span class="badge bg-success">@m.Completed</span></td>
                                    <td><span class="badge bg-danger">@m.Cancelled</span></td>
                                    <td>
                                        <div class="mini-bars">
                                            <div class="mini-bar bg-primary" style="width: @((double)m.Created / maxCount * 100)%;"></div>
                                            <div class="mini-bar bg-success" style="width: @((double)m.Completed / maxCount * 100)%;"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center">Нет данных</p>
            }
        </div>
    };

    private RenderFragment RenderCustomers() => __builder =>
    {
        <div class="section-grid-3">
            @RenderStatCard("Всего клиентов", data!.Overview.TotalCustomers.ToString(), "bi-people", "#3498db", $"Аккаунтов: {data.Overview.TotalAccounts}")
            @RenderStatCard("Новых за месяц", data.Overview.NewAccountsThisMonth.ToString(), "bi-person-plus", "#27ae60", "Рост базы")
            @RenderStatCard("Сред. чек клиента", FormatMoney(data.Overview.AverageOrderValue), "bi-receipt", "#e67e22", "По всем заказам")
        </div>

        <div class="analytics-card">
            <h4><i class="bi bi-trophy"></i> Топ клиентов по выручке</h4>
            @if (data.TopCustomers.Any())
            {
                var maxSpent = data.TopCustomers.Max(c => c.TotalSpent);
                <div class="top-list">
                    @{ int rank = 1; }
                    @foreach (var c in data.TopCustomers)
                    {
                        var pct = maxSpent > 0 ? (double)(c.TotalSpent / maxSpent) * 100 : 0;
                        <div class="top-item">
                            <div class="top-rank @(rank <= 3 ? "top-3" : "")">@rank</div>
                            <div class="top-info">
                                <div class="top-name">@c.CompanyName</div>
                                <div class="top-meta">
                                    <span><i class="bi bi-box-seam"></i> @c.OrderCount заказов</span>
                                    <span><i class="bi bi-cash-stack"></i> @c.DealCount сделок</span>
                                </div>
                            </div>
                            <div class="top-bar-area">
                                <div class="bar-track">
                                    <div class="bar-fill" style="width: @pct.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%; background: linear-gradient(90deg, #3498db, #2ecc71);"></div>
                                </div>
                            </div>
                            <div class="top-value">@FormatMoney(c.TotalSpent)</div>
                        </div>
                        rank++;
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center">Нет данных о клиентах</p>
            }
        </div>
    };

    private RenderFragment RenderExecutors() => __builder =>
    {
        <div class="section-grid-3">
            @RenderStatCard("Исполнителей", data!.Overview.TotalExecutors.ToString(), "bi-person-workspace", "#6f42c1", $"Услуг: {data.Overview.TotalServices}")
            @RenderStatCard("Средний рейтинг", $"{data.Overview.AverageExecutorRating:0.0}", "bi-star-fill", "#f1c40f", "По завершённым сделкам")
            @RenderStatCard("Завершено заказов", data.Overview.CompletedOrders.ToString(), "bi-check2-all", "#27ae60", "Всеми исполнителями")
        </div>

        <div class="analytics-card">
            <h4><i class="bi bi-bar-chart-steps"></i> Производительность исполнителей</h4>
            @if (data.ExecutorPerformance.Any())
            {
                <div class="executor-cards">
                    @foreach (var e in data.ExecutorPerformance)
                    {
                        <div class="executor-card">
                            <div class="executor-header">
                                <div class="executor-avatar"><i class="bi bi-person-workspace"></i></div>
                                <div class="executor-title">
                                    <h5>@e.CompanyName</h5>
                                    <div class="executor-rating">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            <i class="bi @(s <= (int)Math.Round(e.AverageRating) ? "bi-star-fill" : "bi-star")" style="color: #f1c40f;"></i>
                                        }
                                        <span>@e.AverageRating.ToString("0.0") (@e.ReviewCount отз.)</span>
                                    </div>
                                </div>
                                <div class="executor-earned">@FormatMoney(e.TotalEarned)</div>
                            </div>
                            <div class="executor-stats">
                                <div class="executor-stat">
                                    <span class="stat-num">@e.CompletedOrders</span>
                                    <span class="stat-lbl">Выполнено</span>
                                </div>
                                <div class="executor-stat">
                                    <span class="stat-num">@e.ActiveOrders</span>
                                    <span class="stat-lbl">Активных</span>
                                </div>
                                <div class="executor-stat">
                                    <span class="stat-num">@e.ServiceCount</span>
                                    <span class="stat-lbl">Услуг</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center">Нет данных об исполнителях</p>
            }
        </div>
    };

    private RenderFragment RenderServices() => __builder =>
    {
        <div class="section-grid-3">
            @RenderStatCard("Активных услуг", data!.Overview.TotalServices.ToString(), "bi-briefcase", "#3498db", "Доступно клиентам")
            @RenderStatCard("Исполнителей", data.Overview.TotalExecutors.ToString(), "bi-person-workspace", "#6f42c1", "Предоставляют услуги")
            @RenderStatCard("Сделок по услугам", data.Overview.TotalDeals.ToString(), "bi-cash-stack", "#27ae60", "Всего создано")
        </div>

        <div class="analytics-card">
            <h4><i class="bi bi-star"></i> Популярные услуги</h4>
            @if (data.PopularServices.Any())
            {
                <table class="table analytics-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Услуга</th>
                            <th>Категория</th>
                            <th>Исполнитель</th>
                            <th>Цена</th>
                            <th>Заказов</th>
                            <th>Выручка</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = 1; }
                        @foreach (var s in data.PopularServices)
                        {
                            <tr>
                                <td><span class="rank-badge @(idx <= 3 ? "top" : "")">@idx</span></td>
                                <td><strong>@s.Name</strong></td>
                                <td><span class="category-badge">@s.Category</span></td>
                                <td>@s.ExecutorName</td>
                                <td class="text-nowrap">@FormatMoney(s.Price)</td>
                                <td><span class="badge bg-primary">@s.OrderCount</span></td>
                                <td class="text-nowrap"><strong>@FormatMoney(s.TotalRevenue)</strong></td>
                            </tr>
                            idx++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted text-center">Нет данных об услугах</p>
            }
        </div>
    };

    private RenderFragment RenderStatCard(string label, string value, string icon, string color, string footer) => __builder =>
    {
        <div class="rpt-stat-card" style="border-top: 4px solid @color;">
            <div class="rpt-stat-inner">
                <div class="rpt-stat-icon" style="background: @(color)18; color: @color;">
                    <i class="bi @icon"></i>
                </div>
                <div class="rpt-stat-content">
                    <span class="rpt-stat-label">@label</span>
                    <span class="rpt-stat-value">@value</span>
                </div>
            </div>
            <div class="rpt-stat-footer">@footer</div>
        </div>
    };

    private RenderFragment RenderFunnelStep(string label, int value, int maxVal, string color) => __builder =>
    {
        var pct = maxVal > 0 ? (double)value / maxVal * 100 : 0;
        <div class="funnel-step">
            <div class="funnel-label">@label</div>
            <div class="funnel-bar-track">
                <div class="funnel-bar-fill" style="width: @pct.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%; background: @color;">
                    <span>@value</span>
                </div>
            </div>
        </div>
    };

    private string FormatMoney(decimal amount)
    {
        if (amount >= 1_000_000) return $"{amount / 1_000_000:0.#} млн ₽";
        if (amount >= 1_000) return $"{amount:#,##0} ₽";
        return $"{amount:0} ₽";
    }
}

<style>
    .reports-page { padding: 20px; max-width: 1400px; margin: 0 auto; }
    .loading-state, .error-state { text-align: center; padding: 80px 20px; }
    .error-state i { font-size: 3rem; color: #e74c3c; }

    .reports-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px; }
    .reports-header h2 { margin: 0; font-size: 1.8rem; color: #1a1f2e; }
    .reports-header p { margin: 5px 0 0; color: #6c757d; }
    .reports-header-actions .form-select { display: none; }

    .reports-tabs { display: flex; gap: 4px; margin-bottom: 24px; background: #f1f3f5; border-radius: 12px; padding: 4px; overflow-x: auto; }
    .tab-btn { border: none; background: transparent; padding: 10px 20px; border-radius: 10px; font-weight: 500; color: #6c757d; cursor: pointer; transition: all 0.2s; white-space: nowrap; display: flex; align-items: center; gap: 6px; font-size: 0.9rem; }
    .tab-btn:hover { color: #333; background: rgba(255,255,255,0.6); }
    .tab-btn.active { background: #fff; color: #1a1f2e; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .tab-btn i { font-size: 1rem; }

