@page "/accounts"
@using IT_outCRM.Blazor.Services
@using IT_outCRM.Blazor.Models
@using Microsoft.AspNetCore.Authorization
@inject IAuthService AuthService
@inject ITokenStorage TokenStorage
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Пользователи - IT-outCRM</PageTitle>

<AuthorizeView Roles="Admin">
    <Authorized Context="authContext">
        <div class="container-fluid mt-4">
            <div class="page-header">
                <div>
                    <h2><i class="bi bi-people-fill"></i> Управление пользователями</h2>
                    <p class="text-muted">Просмотр, редактирование и управление аккаунтами</p>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <span class="badge bg-secondary fs-6">@users.Count пользователей</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i> @successMessage
                    <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                    <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
                </div>
            }

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 text-muted">Загрузка пользователей...</p>
                </div>
            }
            else if (users.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Пользователь</th>
                                <th>Роль</th>
                                <th>Статус</th>
                                <th>Создан</th>
                                <th>Последний вход</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in users)
                            {
                                <tr class="@(user.IsActive ? "" : "table-secondary")">
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="user-avatar">
                                                @user.Username[0].ToString().ToUpper()
                                            </div>
                                            <div>
                                                <strong>@user.Username</strong>
                                                <div class="text-muted small">@user.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge @GetRoleBadgeClass(user.Role)">@GetRoleDisplayName(user.Role)</span>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Активен</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-snow"></i> Заморожен</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    <td class="text-muted small">@(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.ToString("dd.MM.yyyy HH:mm") : "—")</td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => OpenEditModal(user)" title="Редактировать">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    @onclick="() => ToggleActive(user)" title="@(user.IsActive ? "Заморозить" : "Разморозить")">
                                                <i class="bi @(user.IsActive ? "bi-snow" : "bi-sun")"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteUser(user)" title="Удалить">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people display-1 text-muted"></i>
                    <h3 class="mt-3">Нет пользователей</h3>
                </div>
            }
        </div>

        @* ===== Edit Modal ===== *@
        @if (showEditModal && editingUser != null)
        {
            <div class="modal-backdrop fade show"></div>
            <div class="modal fade show d-block" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Редактирование: @editingUser.Username</h5>
                            <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                        </div>
                        <div class="modal-body">
                            @if (!string.IsNullOrEmpty(editError))
                            {
                                <div class="alert alert-danger small">@editError</div>
                            }
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Имя пользователя</label>
                                <input type="text" class="form-control" @bind="editModel.Username" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Email</label>
                                <input type="email" class="form-control" @bind="editModel.Email" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Роль</label>
                                <select class="form-select" @bind="editModel.Role">
                                    <option value="User">Клиент (User)</option>
                                    <option value="Admin">Администратор (Admin)</option>
                                    <option value="Manager">Менеджер (Manager)</option>
                                    <option value="Executor">Исполнитель (Executor)</option>
                                </select>
                            </div>
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" id="isActiveSwitch" @bind="editIsActive" />
                                <label class="form-check-label" for="isActiveSwitch">
                                    @(editIsActive ? "Активен" : "Заморожен")
                                </label>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Отмена</button>
                            <button type="button" class="btn btn-primary" @onclick="SaveEdit" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg"></i> Сохранить
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning mt-4">
            Доступ запрещен. Управление пользователями доступно только администраторам.
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e9ecef;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .table th {
        font-weight: 600;
        color: #555;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-group-sm .btn {
        padding: 0.3rem 0.5rem;
    }
</style>

@code {
    private List<UserModel> users = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private bool showEditModal = false;
    private UserModel? editingUser;
    private UpdateUserModel editModel = new();
    private bool editIsActive = true;
    private string editError = string.Empty;
    private bool isSaving = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var token = await TokenStorage.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                AuthService.SetToken(token);
                users = await AuthService.GetAllUsersAsync();
            }
            else
            {
                errorMessage = "Не удалось получить токен авторизации.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка загрузки: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void OpenEditModal(UserModel user)
    {
        editingUser = user;
        editModel = new UpdateUserModel
        {
            Username = user.Username,
            Email = user.Email,
            Role = user.Role
        };
        editIsActive = user.IsActive;
        editError = string.Empty;
        showEditModal = true;
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        editingUser = null;
    }

    private async Task SaveEdit()
    {
        if (editingUser == null) return;
        isSaving = true;
        editError = string.Empty;

        try
        {
            editModel.IsActive = editIsActive;

            var token = await TokenStorage.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
                AuthService.SetToken(token);

            var updated = await AuthService.UpdateUserAsync(editingUser.Id, editModel);
            if (updated != null)
            {
                successMessage = $"Пользователь {updated.Username} обновлён";
                CloseEditModal();
                await LoadUsers();
            }
            else
            {
                editError = "Не удалось сохранить изменения.";
            }
        }
        catch (InvalidOperationException ex)
        {
            editError = ex.Message;
        }
        catch (Exception ex)
        {
            editError = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleActive(UserModel user)
    {
        var action = user.IsActive ? "заморозить" : "разморозить";
        if (!await IT_outCRM.Blazor.Services.JsInterop.Confirm(JS, $"Вы уверены, что хотите {action} пользователя {user.Username}?"))
            return;

        try
        {
            var token = await TokenStorage.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
                AuthService.SetToken(token);

            var updated = await AuthService.ToggleUserActiveAsync(user.Id);
            if (updated != null)
            {
                successMessage = updated.IsActive
                    ? $"Пользователь {updated.Username} разморожен"
                    : $"Пользователь {updated.Username} заморожен";
                await LoadUsers();
            }
            else
            {
                errorMessage = "Не удалось изменить статус пользователя.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
    }

    private async Task DeleteUser(UserModel user)
    {
        if (!await IT_outCRM.Blazor.Services.JsInterop.Confirm(JS, $"Вы уверены, что хотите УДАЛИТЬ пользователя {user.Username}? Это действие необратимо!"))
            return;

        try
        {
            var token = await TokenStorage.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
                AuthService.SetToken(token);

            var ok = await AuthService.DeleteUserAsync(user.Id);
            if (ok)
            {
                successMessage = $"Пользователь {user.Username} удалён";
                await LoadUsers();
            }
            else
            {
                errorMessage = "Не удалось удалить пользователя.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка удаления: {ex.Message}";
        }
    }

    private string GetRoleBadgeClass(string role) => role switch
    {
        "Admin" => "bg-danger",
        "Manager" => "bg-warning text-dark",
        "Executor" => "bg-primary",
        "User" => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private string GetRoleDisplayName(string role) => role switch
    {
        "Admin" => "Админ",
        "Manager" => "Менеджер",
        "Executor" => "Исполнитель",
        "User" => "Клиент",
        _ => role
    };
}
