@page "/register"
@using IT_outCRM.Blazor.Models
@using IT_outCRM.Blazor.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<Register> Logger
@rendermode InteractiveServer

<PageTitle>Регистрация - IT-outCRM</PageTitle>

<div class="reg-page">
    <div class="reg-container">
        <div class="reg-card">
            <div class="reg-header">
                <div class="reg-logo">IT-outCRM</div>
                <h2 class="reg-title">Создать аккаунт</h2>
                <p class="reg-subtitle">Заполните форму для регистрации</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="reg-alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
                </div>
            }

            <EditForm Model="RegisterModel" OnValidSubmit="HandleRegister" FormName="registerForm">
                <DataAnnotationsValidator />

                @* === Step indicator === *@
                <div class="reg-steps">
                    <button type="button" class="reg-step @(step == 1 ? "active" : "") @(step > 1 ? "done" : "")" @onclick="() => step = 1">
                        <span class="reg-step-num">1</span>
                        <span class="reg-step-label">Аккаунт</span>
                    </button>
                    <div class="reg-step-line @(step > 1 ? "done" : "")"></div>
                    <button type="button" class="reg-step @(step == 2 ? "active" : "") @(step > 2 ? "done" : "")" @onclick="() => { if (step > 1) step = 2; }">
                        <span class="reg-step-num">2</span>
                        <span class="reg-step-label">Компания</span>
                    </button>
                    <div class="reg-step-line @(step > 2 ? "done" : "")"></div>
                    <button type="button" class="reg-step @(step == 3 ? "active" : "")" @onclick="() => { if (step > 2) step = 3; }">
                        <span class="reg-step-num">3</span>
                        <span class="reg-step-label">Тип</span>
                    </button>
                </div>

                @* === Step 1: Account === *@
                <div class="reg-step-content" style="display: @(step == 1 ? "block" : "none")">
                    <div class="mb-3">
                        <label class="reg-label" for="username">Имя пользователя</label>
                        <div class="reg-input-group">
                            <i class="bi bi-person"></i>
                            <InputText id="username" class="form-control reg-input" @bind-Value="RegisterModel!.Username" placeholder="user123" />
                        </div>
                        <ValidationMessage For="@(() => RegisterModel!.Username)" class="reg-validation" />
                    </div>

                    <div class="mb-3">
                        <label class="reg-label" for="email">Email</label>
                        <div class="reg-input-group">
                            <i class="bi bi-envelope"></i>
                            <InputText id="email" type="email" class="form-control reg-input" @bind-Value="RegisterModel!.Email" placeholder="user@example.com" />
                        </div>
                        <ValidationMessage For="@(() => RegisterModel!.Email)" class="reg-validation" />
                    </div>

                    <div class="mb-3">
                        <label class="reg-label" for="password">Пароль</label>
                        <div class="reg-input-group">
                            <i class="bi bi-lock"></i>
                            <InputText id="password" type="password" class="form-control reg-input" @bind-Value="RegisterModel!.Password" placeholder="Минимум 8 символов" />
                        </div>
                        <ValidationMessage For="@(() => RegisterModel!.Password)" class="reg-validation" />
                        <div class="reg-hint">A-Z, a-z, 0-9 и спецсимвол (!@@#...)</div>
                    </div>

                    <div class="mb-4">
                        <label class="reg-label" for="confirmPassword">Подтвердите пароль</label>
                        <div class="reg-input-group">
                            <i class="bi bi-lock-fill"></i>
                            <InputText id="confirmPassword" type="password" class="form-control reg-input" @bind-Value="RegisterModel!.ConfirmPassword" placeholder="Повторите пароль" />
                        </div>
                        <ValidationMessage For="@(() => RegisterModel!.ConfirmPassword)" class="reg-validation" />
                    </div>

                    <button type="button" class="btn reg-btn-primary w-100" @onclick="GoToStep2">
                        Далее <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>

                @* === Step 2: Company === *@
                <div class="reg-step-content" style="display: @(step == 2 ? "block" : "none")">
                    <div class="mb-3">
                        <label class="reg-label" for="companyName">Название компании</label>
                        <div class="reg-input-group">
                            <i class="bi bi-building"></i>
                            <InputText id="companyName" class="form-control reg-input" @bind-Value="RegisterModel!.CompanyName" placeholder="ООО Ромашка" />
                        </div>
                        <ValidationMessage For="@(() => RegisterModel!.CompanyName)" class="reg-validation" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-7">
                            <label class="reg-label" for="inn">ИНН</label>
                            <div class="reg-input-group">
                                <i class="bi bi-hash"></i>
                                <InputText id="inn" class="form-control reg-input" @bind-Value="RegisterModel!.Inn" placeholder="1234567890" />
                            </div>
                            <ValidationMessage For="@(() => RegisterModel!.Inn)" class="reg-validation" />
                        </div>
                        <div class="col-5">
                            <label class="reg-label" for="legalForm">Форма</label>
                            <InputText id="legalForm" class="form-control reg-input" @bind-Value="RegisterModel!.LegalForm" placeholder="ООО" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="reg-label" for="phone">Телефон</label>
                        <div class="reg-input-group">
                            <i class="bi bi-telephone"></i>
                            <InputText id="phone" class="form-control reg-input" @bind-Value="RegisterModel!.Phone" placeholder="+7 (999) 000-00-00" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn reg-btn-secondary flex-fill" @onclick="() => step = 1">
                            <i class="bi bi-arrow-left me-1"></i> Назад
                        </button>
                        <button type="button" class="btn reg-btn-primary flex-fill" @onclick="GoToStep3">
                            Далее <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>

                @* === Step 3: Type === *@
                <div class="reg-step-content" style="display: @(step == 3 ? "block" : "none")">
                    <p class="reg-type-prompt">Выберите тип аккаунта:</p>

                    <InputRadioGroup @bind-Value="RegisterModel!.UserType">
                        <label class="reg-type-card @(RegisterModel!.UserType == "Customer" ? "selected" : "")" for="typeCustomer">
                            <InputRadio Value="@("Customer")" class="d-none" id="typeCustomer" />
                            <div class="reg-type-icon customer"><i class="bi bi-basket-fill"></i></div>
                            <div class="reg-type-info">
                                <strong>Заказчик</strong>
                                <span>Размещаю заказы на выполнение работ</span>
                            </div>
                            <div class="reg-type-check"><i class="bi bi-check-lg"></i></div>
                        </label>
                        <label class="reg-type-card @(RegisterModel!.UserType == "Executor" ? "selected" : "")" for="typeExecutor">
                            <InputRadio Value="@("Executor")" class="d-none" id="typeExecutor" />
                            <div class="reg-type-icon executor"><i class="bi bi-tools"></i></div>
                            <div class="reg-type-info">
                                <strong>Исполнитель</strong>
                                <span>Выполняю заказы и предоставляю услуги</span>
                            </div>
                            <div class="reg-type-check"><i class="bi bi-check-lg"></i></div>
                        </label>
                    </InputRadioGroup>
                    <ValidationMessage For="@(() => RegisterModel!.UserType)" class="reg-validation" />

                    <div class="d-flex gap-2 mt-4">
                        <button type="button" class="btn reg-btn-secondary flex-fill" @onclick="() => step = 2">
                            <i class="bi bi-arrow-left me-1"></i> Назад
                        </button>
                        <button type="submit" class="btn reg-btn-submit flex-fill" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Зарегистрироваться <i class="bi bi-check-circle ms-1"></i>
                        </button>
                    </div>
                </div>
            </EditForm>

            <div class="reg-footer">
                Уже есть аккаунт? <a href="/login">Войти</a>
            </div>
        </div>
    </div>
</div>

<style>
    .reg-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 2rem 1rem;
    }

    .reg-container {
        width: 100%;
        max-width: 520px;
    }

    .reg-card {
        background: #fff;
        border-radius: 20px;
        padding: 2.5rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
    }

    .reg-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .reg-logo {
        font-size: 1.1rem;
        font-weight: 800;
        color: #667eea;
        letter-spacing: -0.5px;
        margin-bottom: 0.75rem;
    }

    .reg-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 0.25rem;
    }

    .reg-subtitle {
        color: #6c757d;
        margin: 0;
        font-size: 0.95rem;
    }

    /* Steps */
    .reg-steps {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        margin-bottom: 2rem;
    }

    .reg-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0 0.5rem;
    }

    .reg-step-num {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #e9ecef;
        color: #6c757d;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        transition: all 0.3s;
    }

    .reg-step.active .reg-step-num {
        background: #667eea;
        color: #fff;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .reg-step.done .reg-step-num {
        background: #198754;
        color: #fff;
    }

    .reg-step-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: #adb5bd;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .reg-step.active .reg-step-label {
        color: #667eea;
    }

    .reg-step.done .reg-step-label {
        color: #198754;
    }

    .reg-step-line {
        flex: 1;
        max-width: 50px;
        height: 2px;
        background: #e9ecef;
        margin: 0 0.25rem;
        margin-bottom: 18px;
        transition: background 0.3s;
    }

    .reg-step-line.done {
        background: #198754;
    }

    /* Inputs */
    .reg-label {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 0.4rem;
        display: block;
        font-size: 0.9rem;
    }

    .reg-input-group {
        position: relative;
    }

    .reg-input-group i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #adb5bd;
        font-size: 1rem;
        pointer-events: none;
    }

    .reg-input {
        border-radius: 10px;
        padding: 11px 14px 11px 42px;
        border: 2px solid #e9ecef;
        font-size: 0.95rem;
        transition: all 0.2s;
        color: #2c3e50;
        background: #fff;
    }

    .reg-input:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.12);
        background: #fff;
    }

    .col-5 .reg-input {
        padding-left: 14px;
    }

    .reg-hint {
        font-size: 0.78rem;
        color: #adb5bd;
        margin-top: 4px;
        padding-left: 2px;
    }

    .reg-validation {
        color: #dc3545;
        font-size: 0.82rem;
        margin-top: 4px;
        display: block;
    }

    /* Buttons */
    .reg-btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .reg-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.35);
        color: #fff;
    }

    .reg-btn-secondary {
        background: #f8f9fa;
        color: #495057;
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .reg-btn-secondary:hover {
        background: #e9ecef;
        color: #212529;
    }

    .reg-btn-submit {
        background: linear-gradient(135deg, #198754 0%, #20c997 100%);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .reg-btn-submit:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(25, 135, 84, 0.35);
        color: #fff;
    }

    .reg-btn-submit:disabled {
        opacity: 0.65;
    }

    /* Type cards */
    .reg-type-prompt {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .reg-type-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        border: 2px solid #e9ecef;
        border-radius: 14px;
        cursor: pointer;
        transition: all 0.25s;
        margin-bottom: 0.75rem;
    }

    .reg-type-card:hover {
        border-color: #667eea;
        background: #f8f9ff;
    }

    .reg-type-card.selected {
        border-color: #667eea;
        background: linear-gradient(135deg, #f0f3ff 0%, #e8ecff 100%);
    }

    .reg-type-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .reg-type-icon.customer {
        background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
        color: #155724;
    }

    .reg-type-icon.executor {
        background: linear-gradient(135deg, #fff3cd 0%, #ffeeba 100%);
        color: #856404;
    }

    .reg-type-info {
        flex: 1;
    }

    .reg-type-info strong {
        display: block;
        font-size: 1rem;
        color: #1a1a2e;
    }

    .reg-type-info span {
        font-size: 0.82rem;
        color: #6c757d;
    }

    .reg-type-check {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 2px solid #dee2e6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: transparent;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .reg-type-card.selected .reg-type-check {
        background: #667eea;
        border-color: #667eea;
        color: #fff;
    }

    /* Alert */
    .reg-alert {
        background: #fff5f5;
        border: 1px solid #fed7d7;
        color: #c53030;
        border-radius: 10px;
        padding: 0.85rem 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

    /* Footer */
    .reg-footer {
        text-align: center;
        margin-top: 1.75rem;
        padding-top: 1.25rem;
        border-top: 1px solid #f1f3f5;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .reg-footer a {
        color: #667eea;
        font-weight: 600;
        text-decoration: none;
    }

    .reg-footer a:hover {
        text-decoration: underline;
    }

    @@media (max-width: 576px) {
        .reg-card {
            padding: 1.5rem;
            border-radius: 16px;
        }

        .reg-title {
            font-size: 1.4rem;
        }

        .reg-step-label {
            font-size: 0.6rem;
        }
    }
</style>

@code {
    [SupplyParameterFromForm]
    private RegisterModel? RegisterModel { get; set; }
    
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private int step = 1;

    protected override void OnInitialized()
    {
        RegisterModel ??= new RegisterModel();
    }

    private void GoToStep2()
    {
        if (string.IsNullOrWhiteSpace(RegisterModel?.Username) ||
            string.IsNullOrWhiteSpace(RegisterModel?.Email) ||
            string.IsNullOrWhiteSpace(RegisterModel?.Password))
        {
            errorMessage = "Заполните все обязательные поля";
            return;
        }
        if (RegisterModel.Password != RegisterModel.ConfirmPassword)
        {
            errorMessage = "Пароли не совпадают";
            return;
        }
        errorMessage = string.Empty;
        step = 2;
    }

    private void GoToStep3()
    {
        if (string.IsNullOrWhiteSpace(RegisterModel?.CompanyName) ||
            string.IsNullOrWhiteSpace(RegisterModel?.Inn))
        {
            errorMessage = "Укажите название компании и ИНН";
            return;
        }
        errorMessage = string.Empty;
        step = 3;
    }

    private async Task HandleRegister()
    {
        if (RegisterModel == null) return;
        
        if (string.IsNullOrWhiteSpace(RegisterModel.UserType))
        {
            errorMessage = "Выберите тип аккаунта";
            return;
        }

        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            RegisterModel.Role = RegisterModel.UserType == "Executor" ? "Executor" : "User";

            var result = await AuthService.RegisterAsync(RegisterModel);
            
            if (result != null)
            {
                Logger.LogInformation("User {Username} registered successfully", result.Username);
                await Task.Delay(100);
                Navigation.NavigateTo("/dashboard", forceLoad: false);
            }
            else
            {
                errorMessage = "Ошибка при регистрации. Попробуйте ещё раз.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during registration");
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
