@page "/customers"
@using IT_outCRM.Blazor.Services
@using IT_outCRM.Blazor.Models
@using Microsoft.AspNetCore.Authorization
@inject ICustomerService CustomerService
@inject ITokenStorage TokenStorage
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Клиенты - IT-outCRM</PageTitle>

<AuthorizeView>
    <Authorized Context="authContext">
        <div class="customers-container">
            <!-- Заголовок страницы -->
            <div class="page-header">
                <div class="header-content">
                    <h1><i class="bi bi-people-fill"></i> Управление клиентами</h1>
                    <p class="header-subtitle">Всего клиентов: <strong>@filteredCustomers.Count</strong></p>
                </div>
                <button class="btn btn-add-customer" @onclick="CreateCustomer">
                    <i class="bi bi-person-plus-fill"></i> ДОБАВИТЬ КЛИЕНТА
                </button>
            </div>

            <!-- Панель поиска и фильтров -->
            <div class="filters-section">
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" 
                               class="search-input" 
                               placeholder="Поиск по аккаунту или компании..." 
                               @bind="searchTerm" 
                               @bind:event="oninput" 
                               @onkeyup="FilterCustomers" />
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="clear-search" @onclick="ClearSearch">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <button class="btn btn-reset-filters" @onclick="ResetFilters">
                            <i class="bi bi-arrow-counterclockwise"></i> СБРОСИТЬ ФИЛЬТРЫ
                        </button>
                    }
                </div>
            </div>

            <!-- Сообщения об ошибках -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@errorMessage</span>
                    <button type="button" class="alert-close" @onclick="() => errorMessage = string.Empty">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }

            <!-- Состояние загрузки -->
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <p>Загрузка клиентов...</p>
                </div>
            }
            else
            {
                @if (filteredCustomers.Any())
                {
                    <!-- Сетка карточек клиентов -->
                    <div class="customers-grid">
                        @foreach (var customer in filteredCustomers)
                        {
                            <div class="customer-card">
                                <!-- Заголовок карточки с градиентом -->
                                <div class="card-header-gradient">
                                    <div class="avatar-circle">
                                        @if (string.IsNullOrEmpty(customer.AccountName))
                                        {
                                            <i class="bi bi-question-circle-fill"></i>
                                        }
                                        else
                                        {
                                            <span>@GetInitials(customer.AccountName)</span>
                                        }
                                    </div>
                                </div>
                                
                                <!-- Тело карточки -->
                                <div class="card-body">
                                    <h3 class="customer-name">@(string.IsNullOrEmpty(customer.AccountName) ? "Без имени" : customer.AccountName)</h3>
                                    
                                    <div class="customer-details">
                                        <div class="detail-row">
                                            <i class="bi bi-building detail-icon"></i>
                                            <div class="detail-content">
                                                <span class="detail-label">Компания:</span>
                                                <span class="detail-value">@(string.IsNullOrEmpty(customer.CompanyName) ? "Не указано" : customer.CompanyName)</span>
                                            </div>
                                        </div>
                                        
                                        <div class="detail-row">
                                            <i class="bi bi-card-checklist detail-icon"></i>
                                            <div class="detail-content">
                                                <span class="detail-label">ID Аккаунта:</span>
                                                <span class="detail-value code">@FormatGuid(customer.AccountId)</span>
                                            </div>
                                        </div>
                                        
                                        <div class="detail-row">
                                            <i class="bi bi-briefcase detail-icon"></i>
                                            <div class="detail-content">
                                                <span class="detail-label">ID Компании:</span>
                                                <span class="detail-value code">@FormatGuid(customer.CompanyId)</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Футер карточки с действиями -->
                                <div class="card-footer">
                                    <button class="btn-action btn-view" 
                                            @onclick:stopPropagation="true" 
                                            @onclick="() => ViewCustomer(customer.Id)"
                                            title="Просмотр">
                                        <i class="bi bi-eye"></i> ПРОСМОТР
                                    </button>
                                    <button class="btn-action btn-edit" 
                                            @onclick:stopPropagation="true" 
                                            @onclick="() => EditCustomer(customer.Id)"
                                            title="Изменить">
                                        <i class="bi bi-pencil"></i> ИЗМЕНИТЬ
                                    </button>
                                    <button class="btn-action btn-delete" 
                                            @onclick:stopPropagation="true" 
                                            @onclick="() => ConfirmDelete(customer.Id, customer.AccountName)"
                                            title="Удалить">
                                        <i class="bi bi-trash"></i> УДАЛИТЬ
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Пустое состояние -->
                    <div class="empty-state">
                        <div class="empty-icon">
                        <i class="bi bi-people"></i>
                        </div>
                        <h3>@(string.IsNullOrEmpty(searchTerm) ? "Нет клиентов" : "Ничего не найдено")</h3>
                        <p class="empty-text">
                            @(string.IsNullOrEmpty(searchTerm) 
                                ? "Добавьте первого клиента, чтобы начать работу" 
                                : "По вашему запросу ничего не найдено. Попробуйте изменить критерии поиска.")
                        </p>
                        @if (string.IsNullOrEmpty(searchTerm))
                        {
                            <button class="btn btn-empty-action" @onclick="CreateCustomer">
                                <i class="bi bi-person-plus-fill"></i> Добавить клиента
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-empty-action" @onclick="ResetFilters">
                                <i class="bi bi-arrow-counterclockwise"></i> Сбросить фильтры
                            </button>
                        }
                    </div>
                }
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

<style>
    .customers-container {
        padding: 30px;
        max-width: 1600px;
        margin: 0 auto;
        min-height: calc(100vh - 200px);
    }

    /* Заголовок страницы */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e9ecef;
    }

    .header-content h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #2c3e50;
        margin: 0 0 8px 0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-content h1 i {
        color: #11998e;
    }

    .header-subtitle {
        font-size: 1.1rem;
        color: #6c757d;
        margin: 0;
    }

    .header-subtitle strong {
        color: #11998e;
        font-weight: 600;
    }

    .btn-add-customer {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        border: none;
        padding: 14px 28px;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 15px rgba(17, 153, 142, 0.3);
    }

    .btn-add-customer:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(17, 153, 142, 0.4);
    }

    .btn-add-customer:active {
        transform: translateY(0);
    }

    /* Панель поиска */
    .filters-section {
        margin-bottom: 30px;
    }

    .search-container {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .search-input-wrapper {
        flex: 1;
        position: relative;
        max-width: 600px;
    }

    .search-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
        font-size: 1.2rem;
        z-index: 1;
    }

    .search-input {
        width: 100%;
        padding: 16px 50px 16px 55px;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: white;
    }

    .search-input:focus {
        outline: none;
        border-color: #11998e;
        box-shadow: 0 0 0 3px rgba(17, 153, 142, 0.1);
    }

    .clear-search {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #6c757d;
        cursor: pointer;
        padding: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
    }

    .clear-search:hover {
        color: #dc3545;
    }

    .btn-reset-filters {
        background: #f8f9fa;
        color: #6c757d;
        border: 2px solid #dee2e6;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }

    .btn-reset-filters:hover {
        background: #e9ecef;
        border-color: #adb5bd;
    }

    /* Сообщение об ошибке */
    .alert {
        padding: 16px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c2c7;
    }

    .alert-close {
        position: absolute;
        right: 15px;
        background: none;
        border: none;
        color: inherit;
        cursor: pointer;
        padding: 5px;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .alert-close:hover {
        opacity: 1;
    }

    /* Состояние загрузки */
    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #11998e;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 20px;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .loading-state p {
        color: #6c757d;
        font-size: 1.1rem;
    }

    /* Сетка карточек */
    .customers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 25px;
    }

    /* Карточка клиента */
    .customer-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .customer-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }

    /* Заголовок карточки с градиентом */
    .card-header-gradient {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        padding: 40px 20px;
        text-align: center;
        position: relative;
    }

    .avatar-circle {
        width: 90px;
        height: 90px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        font-size: 2.2rem;
        font-weight: 700;
        color: #11998e;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .avatar-circle i {
        font-size: 3rem;
        color: #6c757d;
    }

    /* Тело карточки */
    .card-body {
        padding: 25px;
        flex: 1;
    }

    .customer-name {
        font-size: 1.4rem;
        font-weight: 600;
        color: #2c3e50;
        margin: 0 0 20px 0;
        text-align: center;
    }

    .customer-details {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .detail-icon {
        color: #11998e;
        font-size: 1.3rem;
        margin-top: 2px;
        flex-shrink: 0;
    }

    .detail-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .detail-label {
        font-size: 0.85rem;
        color: #6c757d;
        font-weight: 500;
    }

    .detail-value {
        font-size: 1rem;
        color: #2c3e50;
        font-weight: 500;
        word-break: break-word;
    }

    .detail-value.code {
        font-family: 'Courier New', monospace;
        font-size: 0.9rem;
        color: #495057;
        background: #f8f9fa;
        padding: 4px 8px;
        border-radius: 4px;
        display: inline-block;
    }

    /* Футер карточки */
    .card-footer {
        padding: 20px;
        background: #f8f9fa;
        display: flex;
        gap: 10px;
        border-top: 1px solid #e9ecef;
    }

    .btn-action {
        flex: 1;
        padding: 10px 12px;
        border: none;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-view {
        background: #e7f3ff;
        color: #0066cc;
    }

    .btn-view:hover {
        background: #cfe7ff;
        transform: translateY(-1px);
    }

    .btn-edit {
        background: #fff3cd;
        color: #856404;
    }

    .btn-edit:hover {
        background: #ffeaa7;
        transform: translateY(-1px);
    }

    .btn-delete {
        background: #f8d7da;
        color: #721c24;
    }

    .btn-delete:hover {
        background: #f5c2c7;
        transform: translateY(-1px);
    }

    /* Пустое состояние */
    .empty-state {
        text-align: center;
        padding: 80px 40px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }

    .empty-icon {
        font-size: 5rem;
        color: #dee2e6;
        margin-bottom: 25px;
    }

    .empty-state h3 {
        font-size: 1.8rem;
        color: #2c3e50;
        margin: 0 0 15px 0;
        font-weight: 600;
    }

    .empty-text {
        font-size: 1.1rem;
        color: #6c757d;
        margin: 0 0 30px 0;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }

    .btn-empty-action {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        border: none;
        padding: 14px 32px;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 15px rgba(17, 153, 142, 0.3);
    }

    .btn-empty-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(17, 153, 142, 0.4);
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .customers-container {
            padding: 20px;
        }

        .page-header {
            flex-direction: column;
            gap: 20px;
            align-items: stretch;
        }

        .header-content h1 {
            font-size: 2rem;
        }

        .btn-add-customer {
            width: 100%;
            justify-content: center;
        }

        .search-container {
            flex-direction: column;
        }

        .search-input-wrapper {
            max-width: 100%;
        }

        .customers-grid {
            grid-template-columns: 1fr;
        }

        .card-footer {
            flex-direction: column;
        }

        .btn-action {
            width: 100%;
        }
    }
</style>

@code {
    private List<CustomerModel> allCustomers = new();
    private List<CustomerModel> filteredCustomers = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string searchTerm = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            var token = await TokenStorage.GetTokenAsync();
            
            if (!string.IsNullOrEmpty(token))
            {
                CustomerService.SetToken(token);
                await LoadCustomers();
            }
            else
            {
                errorMessage = "Не удалось получить токен авторизации.";
                isLoading = false;
            }
            StateHasChanged();
        }
    }

    private async Task LoadCustomers()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            allCustomers = await CustomerService.GetAllAsync();
            FilterCustomers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка загрузки клиентов: {ex.Message}";
            Console.WriteLine($"[CustomersList] Error loading customers: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FilterCustomers()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredCustomers = allCustomers.ToList();
        }
        else
    {
        filteredCustomers = allCustomers.Where(c =>
                (!string.IsNullOrEmpty(c.AccountName) && c.AccountName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrEmpty(c.CompanyName) && c.CompanyName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        ).ToList();
        }
    }

    private void ResetFilters()
    {
        searchTerm = string.Empty;
        FilterCustomers();
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        FilterCustomers();
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        }
        
        if (name.Length >= 2)
        {
            return name.Substring(0, 2).ToUpper();
        }
        
        return name.ToUpper();
    }

    private string FormatGuid(Guid guid)
    {
        var str = guid.ToString();
        return $"{str.Substring(0, 8)}...";
    }

    private void CreateCustomer()
    {
        Navigation.NavigateTo("/customers/create");
    }

    private void ViewCustomer(Guid customerId)
    {
        Navigation.NavigateTo($"/customers/{customerId}");
    }

    private void EditCustomer(Guid customerId)
    {
        Navigation.NavigateTo($"/customers/edit/{customerId}");
    }

    private async Task ConfirmDelete(Guid customerId, string customerName)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", 
            $"Вы уверены, что хотите удалить клиента '{customerName}'?\n\nЭто действие нельзя отменить.");
        
        if (confirmed)
        {
            await DeleteCustomer(customerId);
        }
    }

    private async Task DeleteCustomer(Guid customerId)
    {
        try
        {
            var token = await TokenStorage.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                CustomerService.SetToken(token);
            }

            var success = await CustomerService.DeleteAsync(customerId);
            if (success)
            {
                await LoadCustomers();
            }
            else
            {
                errorMessage = "Ошибка при удалении клиента. Попробуйте еще раз.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при удалении клиента: {ex.Message}";
            Console.WriteLine($"[CustomersList] Error deleting customer: {ex.Message}");
        }
    }
}
