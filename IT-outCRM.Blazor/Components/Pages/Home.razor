@page "/"
@using IT_outCRM.Blazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>IT-outCRM - Управление IT-аутсорсингом</PageTitle>

<div class="landing-page">
    @* Premium Hero Section *@
    <section class="premium-hero-section text-center">
        <div class="premium-hero-background"></div>
        <div class="container position-relative z-2">
            <div class="row justify-content-center">
                <div class="col-lg-9">
                    <h1 class="premium-title mb-4">
                        IT-outCRM
                    </h1>
                    <p class="premium-subtitle mb-4">
                        Корпоративная платформа для управления IT-аутсорсингом премиум-класса
                    </p>
                    <p class="premium-description mb-5">
                        Доверьте управление своей IT-компанией профессионалам. 
                        Мы обеспечиваем высочайший уровень сервиса, безопасности и надежности.
                    </p>
                    
                    <div class="premium-cta-buttons d-flex gap-3 justify-content-center flex-wrap">
                        <AuthorizeView>
                            <Authorized>
                                <a href="dashboard" class="btn-premium-primary btn-lg">
                                    <span>Перейти в систему</span>
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </Authorized>
                            <NotAuthorized>
                                <a href="login" class="btn-premium-primary btn-lg">
                                    <span>Вход в систему</span>
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                                <a href="register" class="btn-premium-secondary btn-lg">
                                    <span>Начать сотрудничество</span>
                                    <i class="bi bi-rocket-takeoff"></i>
                                </a>
                            </NotAuthorized>
                        </AuthorizeView>
                    </div>
                </div>
            </div>
        </div>
        <div class="premium-hero-pattern"></div>
    </section>

    @* Trust Indicators *@
    <section class="trust-section py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3 col-6">
                    <div class="trust-stat text-center">
                        <div class="trust-number">100%</div>
                        <div class="trust-label">Надежность</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="trust-stat text-center">
                        <div class="trust-number">24/7</div>
                        <div class="trust-label">Поддержка</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="trust-stat text-center">
                        <div class="trust-number">ISO</div>
                        <div class="trust-label">Сертификация</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="trust-stat text-center">
                        <div class="trust-number">5+</div>
                        <div class="trust-label">Лет опыта</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* Premium Benefits Section *@
    <section class="premium-features-section py-6">
        <div class="container">
            <div class="text-center mb-5">
                <div class="section-badge mb-3">
                    <i class="bi bi-star-fill"></i> Преимущества
                </div>
                <h2 class="premium-section-title mb-3">Почему выбирают IT-outCRM</h2>
                <p class="premium-section-subtitle">Корпоративные решения для серьезного бизнеса</p>
                <div class="premium-divider mx-auto mt-4"></div>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="premium-feature-card h-100">
                        <div class="premium-feature-icon">
                            <i class="bi bi-person-gear"></i>
                        </div>
                        <h4 class="premium-feature-title">Управление партнерами</h4>
                        <p class="premium-feature-text">
                            Координируйте работу с партнерами-исполнителями. 
                            Отслеживайте рейтинги, специализации и эффективность каждого партнера.
                        </p>
                        <div class="premium-feature-accent"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-feature-card h-100">
                        <div class="premium-feature-icon">
                            <i class="bi bi-clipboard-check-fill"></i>
                        </div>
                        <h4 class="premium-feature-title">Управление заказами</h4>
                        <p class="premium-feature-text">
                            Полный контроль над жизненным циклом заказов. 
                            От создания до завершения с автоматическим назначением исполнителей.
                        </p>
                        <div class="premium-feature-accent"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-feature-card h-100">
                        <div class="premium-feature-icon">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h4 class="premium-feature-title">Работа с клиентами</h4>
                        <p class="premium-feature-text">
                            Централизованная база клиентов и компаний. 
                            История заказов, контактная информация и полная картина взаимодействия.
                        </p>
                        <div class="premium-feature-accent"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-feature-card h-100">
                        <div class="premium-feature-icon">
                            <i class="bi bi-bar-chart-line-fill"></i>
                        </div>
                        <h4 class="premium-feature-title">Аналитика и отчеты</h4>
                        <p class="premium-feature-text">
                            Финансовые отчеты, статистика по партнерам и клиентам. 
                            Принимайте решения на основе данных.
                        </p>
                        <div class="premium-feature-accent"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-feature-card h-100">
                        <div class="premium-feature-icon">
                            <i class="bi bi-bell-fill"></i>
                        </div>
                        <h4 class="premium-feature-title">Автоматические уведомления</h4>
                        <p class="premium-feature-text">
                            Email-уведомления о статусах заказов, новых заказах и важных событиях. 
                            Все участники всегда в курсе.
                        </p>
                        <div class="premium-feature-accent"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-feature-card h-100">
                        <div class="premium-feature-icon">
                            <i class="bi bi-lock-fill"></i>
                        </div>
                        <h4 class="premium-feature-title">Безопасность и доступ</h4>
                        <p class="premium-feature-text">
                            Ролевая модель доступа (Администратор, Менеджер, Клиент). 
                            Каждый видит только то, что ему нужно.
                        </p>
                        <div class="premium-feature-accent"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* Premium How It Works *@
    <section class="premium-process-section py-6">
        <div class="container">
            <div class="text-center mb-5">
                <div class="section-badge mb-3">
                    <i class="bi bi-gear-fill"></i> Процесс работы
                </div>
                <h2 class="premium-section-title mb-3">Как это работает</h2>
                <p class="premium-section-subtitle">Профессиональный подход к каждому этапу</p>
                <div class="premium-divider mx-auto mt-4"></div>
            </div>
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="premium-step-card text-center">
                        <div class="premium-step-number">
                            <span>01</span>
                        </div>
                        <h5 class="premium-step-title">Клиент создает заказ</h5>
                        <p class="premium-step-text">
                            Клиент регистрируется в системе и создает заказ с описанием требуемых услуг.
                        </p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="premium-step-card text-center">
                        <div class="premium-step-number">
                            <span>02</span>
                        </div>
                        <h5 class="premium-step-title">Менеджер обрабатывает</h5>
                        <p class="premium-step-text">
                            Менеджер проверяет заказ, уточняет детали и назначает подходящего партнера-исполнителя.
                        </p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="premium-step-card text-center">
                        <div class="premium-step-number">
                            <span>03</span>
                        </div>
                        <h5 class="premium-step-title">Партнер выполняет</h5>
                        <p class="premium-step-text">
                            Партнер-исполнитель берет заказ в работу, выполняет его и обновляет статус.
                        </p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="premium-step-card text-center">
                        <div class="premium-step-number premium-step-number-final">
                            <span>04</span>
                        </div>
                        <h5 class="premium-step-title">Заказ завершен</h5>
                        <p class="premium-step-text">
                            После завершения заказ закрывается, все участники получают уведомления.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* Premium For Whom *@
    <section class="premium-cta-section py-6">
        <div class="premium-cta-background"></div>
        <div class="container position-relative z-2">
            <div class="text-center mb-5">
                <div class="section-badge section-badge-light mb-3">
                    <i class="bi bi-people-fill"></i> Аудитория
                </div>
                <h2 class="premium-section-title premium-section-title-light mb-3">Для кого эта система?</h2>
                <p class="premium-section-subtitle premium-section-subtitle-light">Корпоративные решения для каждой роли</p>
                <div class="premium-divider premium-divider-light mx-auto mt-4"></div>
            </div>
            <div class="row justify-content-center g-4">
                <div class="col-md-4">
                    <div class="premium-role-card h-100">
                        <div class="premium-role-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <h5 class="premium-role-title">Для IT-компаний</h5>
                        <p class="premium-role-text">
                            Управляйте заказами, координируйте работу с партнерами-исполнителями, 
                            отслеживайте финансовые показатели и обеспечивайте качественный сервис для клиентов.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-role-card h-100">
                        <div class="premium-role-icon">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <h5 class="premium-role-title">Для партнеров-исполнителей</h5>
                        <p class="premium-role-text">
                            Получайте новые заказы, отслеживайте свой рейтинг и статистику, 
                            общайтесь с клиентами и менеджерами в единой системе.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="premium-role-card h-100">
                        <div class="premium-role-icon">
                            <i class="bi bi-people"></i>
                        </div>
                        <h5 class="premium-role-title">Для клиентов</h5>
                        <p class="premium-role-text">
                            Создавайте заказы, отслеживайте их статус в реальном времени, 
                            общайтесь с исполнителями и получайте качественные IT-услуги.
                        </p>
                    </div>
                </div>
            </div>
            <div class="row mt-5">
                <div class="col-12 text-center">
                    <AuthorizeView>
                        <NotAuthorized>
                            <a href="register" class="btn-premium-primary btn-lg">
                                <span>Начать сотрудничество</span>
                                <i class="bi bi-arrow-right"></i>
                            </a>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </section>

    @* Premium Footer *@
    <footer class="premium-footer py-5">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-4 mb-4 mb-md-0">
                    <h5 class="premium-footer-title mb-3">IT-outCRM</h5>
                    <p class="premium-footer-text">
                        Премиум платформа для управления IT-аутсорсинговой компанией. 
                        Профессиональные решения для серьезного бизнеса.
                    </p>
                </div>
                <div class="col-md-4 mb-4 mb-md-0">
                    <h6 class="premium-footer-heading mb-3">Гарантии</h6>
                    <ul class="premium-footer-list">
                        <li><i class="bi bi-shield-check"></i> Безопасность данных</li>
                        <li><i class="bi bi-clock-history"></i> Круглосуточная поддержка</li>
                        <li><i class="bi bi-award"></i> Сертифицированные решения</li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="premium-footer-heading mb-3">Контакты</h6>
                    <ul class="premium-footer-list">
                        <li><i class="bi bi-envelope"></i> support@it-outcrm.com</li>
                        <li><i class="bi bi-telephone"></i> +7 (495) 123-45-67</li>
                        <li><i class="bi bi-geo-alt"></i> Москва, Россия</li>
                    </ul>
                </div>
            </div>
            <div class="premium-footer-divider my-4"></div>
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <p class="premium-footer-copyright mb-0">
                        &copy; @DateTime.Now.Year IT-outCRM. Все права защищены.
                    </p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="premium-footer-version mb-0">
                        Версия 2.0.0 Premium Edition
                    </p>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    :root {
        --premium-black: #0a0e13;
        --premium-dark: #1a1f2e;
        --premium-blue: #1e3a5f;
        --premium-silver: #8b8b8b;
        --premium-silver-light: #b0b0b0;
        --premium-silver-dark: #6b6b6b;
        --premium-white: #ffffff;
        --premium-gray: #f8f9fa;
        --premium-text: #2c3e50;
        --premium-text-light: #6c757d;
    }

    /* Premium Hero Section */
    .premium-hero-section {
        background: linear-gradient(135deg, var(--premium-black) 0%, var(--premium-dark) 50%, var(--premium-blue) 100%);
        padding: 180px 0 160px;
        margin-top: -3.5rem;
        position: relative;
        overflow: hidden;
    }

    .premium-hero-background {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            radial-gradient(circle at 20% 50%, rgba(139, 139, 139, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(30, 58, 95, 0.2) 0%, transparent 50%);
        opacity: 0.6;
    }

    .premium-hero-pattern {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: 
            repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(139, 139, 139, 0.03) 35px, rgba(139, 139, 139, 0.03) 70px);
        opacity: 0.5;
    }

    .premium-badge {
        display: inline-block;
        padding: 8px 24px;
        background: linear-gradient(135deg, var(--premium-silver) 0%, var(--premium-silver-light) 100%);
        color: var(--premium-black);
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 4px 15px rgba(139, 139, 139, 0.3);
    }

    .premium-title {
        font-size: 5rem;
        font-weight: 800;
        color: var(--premium-white);
        letter-spacing: -2px;
        margin-bottom: 1.5rem;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        background: linear-gradient(135deg, var(--premium-white) 0%, var(--premium-silver-light) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        user-select: none;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        outline: none;
    }

    .premium-subtitle {
        font-size: 1.6rem;
        color: rgba(255, 255, 255, 0.95);
        font-weight: 300;
        letter-spacing: 0.5px;
        line-height: 1.6;
    }

    .premium-description {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.8;
        max-width: 700px;
        margin: 0 auto;
    }

    .premium-cta-buttons {
        margin-top: 3rem;
    }

    .btn-premium-primary {
        background: linear-gradient(135deg, var(--premium-silver) 0%, var(--premium-silver-light) 100%);
        color: var(--premium-black);
        border: none;
        padding: 16px 40px;
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 0.5px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(139, 139, 139, 0.4);
        text-decoration: none;
    }

    .btn-premium-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(139, 139, 139, 0.5);
        color: var(--premium-black);
    }

    .btn-premium-secondary {
        background: transparent;
        color: var(--premium-white);
        border: 2px solid var(--premium-silver);
        padding: 14px 38px;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.5px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-premium-secondary:hover {
        background: var(--premium-silver);
        color: var(--premium-black);
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(139, 139, 139, 0.3);
    }

    /* Trust Section */
    .trust-section {
        background: var(--premium-white);
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .trust-stat {
        padding: 2rem 1rem;
    }

    .trust-number {
        font-size: 3rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--premium-blue) 0%, var(--premium-silver) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
    }

    .trust-label {
        font-size: 0.9rem;
        color: var(--premium-text-light);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Premium Features */
    .premium-features-section {
        background: var(--premium-gray);
    }

    .section-badge {
        display: inline-block;
        padding: 6px 20px;
        background: linear-gradient(135deg, var(--premium-silver) 0%, var(--premium-silver-light) 100%);
        color: var(--premium-black);
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .section-badge-light {
        background: rgba(139, 139, 139, 0.2);
        color: var(--premium-white);
    }

    .premium-section-title {
        font-size: 3rem;
        font-weight: 800;
        color: var(--premium-text);
        letter-spacing: -1px;
    }

    .premium-section-title-light {
        color: var(--premium-white);
    }

    .premium-section-subtitle {
        font-size: 1.2rem;
        color: var(--premium-text-light);
        font-weight: 300;
    }

    .premium-section-subtitle-light {
        color: rgba(255, 255, 255, 0.9);
    }

    .premium-divider {
        height: 4px;
        width: 80px;
        background: linear-gradient(90deg, var(--premium-silver) 0%, var(--premium-silver-light) 100%);
        border-radius: 2px;
    }

    .premium-divider-light {
        background: linear-gradient(90deg, var(--premium-silver) 0%, var(--premium-silver-light) 100%);
    }

    .premium-feature-card {
        background: var(--premium-white);
        border-radius: 16px;
        padding: 2.5rem;
        position: relative;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .premium-feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--premium-silver) 0%, var(--premium-silver-light) 100%);
        transform: scaleX(0);
        transition: transform 0.4s ease;
    }

    .premium-feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
    }

    .premium-feature-card:hover::before {
        transform: scaleX(1);
    }

    .premium-feature-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, var(--premium-blue) 0%, var(--premium-dark) 100%);
        border-radius: 16px;
        display: flex !important;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        box-shadow: 0 8px 20px rgba(30, 58, 95, 0.2);
        transition: all 0.3s ease;
        position: relative;
    }

    .premium-feature-icon i {
        display: block !important;
        line-height: 1;
        font-size: 2.2rem !important;
        color: var(--premium-white) !important;
        opacity: 1 !important;
        font-style: normal;
        font-weight: normal;
    }

    .premium-feature-card:hover .premium-feature-icon {
        transform: translateY(-5px) scale(1.1);
        box-shadow: 0 12px 30px rgba(30, 58, 95, 0.3);
    }

    .premium-feature-card:hover .premium-feature-icon i {
        color: var(--premium-silver-light) !important;
    }

    .premium-feature-title {
        font-size: 1.4rem;
