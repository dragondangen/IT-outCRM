@page "/all-services"
@using IT_outCRM.Blazor.Services
@using IT_outCRM.Blazor.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IServiceService ServiceService
@inject ITokenStorage TokenStorage
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Все услуги - IT-outCRM</PageTitle>

<AuthorizeView>
    <Authorized Context="authContext">
        <div class="all-services-container">
    <div class="page-header">
        <div>
            <h2>💼 Все услуги</h2>
            <p class="text-muted">Просмотр всех услуг, предлагаемых исполнителями</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }

    <!-- Поиск и фильтры -->
    <div class="filters-card">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" class="form-control" placeholder="Поиск по названию, описанию или категории..." 
                           @bind="searchTerm" @bind:event="oninput" @onkeyup="FilterServices" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @onchange="OnCategoryFilterChanged">
                    <option value="">Все категории</option>
                    @foreach (var category in uniqueCategories)
                    {
                        <option value="@category">@category</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @onchange="OnStatusFilterChanged">
                    <option value="">Все статусы</option>
                    <option value="active">Активные</option>
                    <option value="inactive">Неактивные</option>
                </select>
            </div>
        </div>
        <div class="row g-3 mt-2">
            <div class="col-md-12">
                <button class="btn btn-outline-secondary" @onclick="ResetFilters">
                    <i class="bi bi-x-circle"></i> Сбросить фильтры
                </button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="mt-3">Загрузка услуг...</p>
        </div>
    }
    else
    {
        @if (filteredServices.Any())
        {
            <div class="services-grid">
                @foreach (var service in filteredServices)
                {
                    <div class="service-card">
                        <div class="service-card-header">
                            <h5>@service.Name</h5>
                            @if (service.IsActive)
                            {
                                <span class="badge bg-success">Активна</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Неактивна</span>
                            }
                        </div>
                        <div class="service-card-body">
                            <p class="description">@(string.IsNullOrEmpty(service.Description) ? "Нет описания" : (service.Description.Length > 150 ? service.Description.Substring(0, 150) + "..." : service.Description))</p>
                            <div class="service-info">
                                <div class="info-item">
                                    <i class="bi bi-cash"></i>
                                    <span>@service.Price.ToString("C")</span>
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-clock"></i>
                                    <span>@service.Duration часов</span>
                                </div>
                                @if (!string.IsNullOrEmpty(service.Category))
                                {
                                    <div class="info-item">
                                        <i class="bi bi-tag"></i>
                                        <span>@service.Category</span>
                                    </div>
                                }
                                <div class="info-item">
                                    <i class="bi bi-calendar"></i>
                                    <span>Создано: @service.CreatedAt.ToString("dd.MM.yyyy")</span>
                                </div>
                            </div>
                        </div>
                        <div class="service-card-footer">
                            <button class="btn btn-sm btn-outline-info" @onclick="() => ViewService(service)">
                                <i class="bi bi-eye"></i> Просмотр
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-briefcase"></i>
                <h3>Нет услуг</h3>
                <p class="text-muted">@(string.IsNullOrEmpty(searchTerm) ? "Исполнители еще не добавили услуги" : "По вашему запросу ничего не найдено")</p>
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <button class="btn btn-primary" @onclick="ResetFilters">
                        <i class="bi bi-x-circle"></i> Сбросить фильтры
                    </button>
                }
            </div>
        }
    }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

<!-- Модальное окно для просмотра услуги -->
@if (showModal && selectedService != null)
{
    <div class="modal-backdrop" @onclick="CloseModal"></div>
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@selectedService.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="service-details">
                        <div class="detail-row">
                            <label>Описание:</label>
                            <p>@(string.IsNullOrEmpty(selectedService.Description) ? "Нет описания" : selectedService.Description)</p>
                        </div>
                        <div class="detail-row">
                            <label>Цена:</label>
                            <p class="price-value">@selectedService.Price.ToString("C")</p>
                        </div>
                        <div class="detail-row">
                            <label>Длительность:</label>
                            <p>@selectedService.Duration часов</p>
                        </div>
                        @if (!string.IsNullOrEmpty(selectedService.Category))
                        {
                            <div class="detail-row">
                                <label>Категория:</label>
                                <p><span class="badge bg-primary">@selectedService.Category</span></p>
                            </div>
                        }
                        <div class="detail-row">
                            <label>Статус:</label>
                            <p>
                                @if (selectedService.IsActive)
                                {
                                    <span class="badge bg-success">Активна</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Неактивна</span>
                                }
                            </p>
                        </div>
                        <div class="detail-row">
                            <label>Дата создания:</label>
                            <p>@selectedService.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>
                        @if (selectedService.UpdatedAt.HasValue)
                        {
                            <div class="detail-row">
                                <label>Последнее обновление:</label>
                                <p>@selectedService.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</p>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Закрыть</button>
                </div>
            </div>
        </div>
    </div>
}

