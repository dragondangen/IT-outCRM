</style>

@code {
    private List<ServiceModel> allServices = new();
    private List<ServiceModel> filteredServices = new();
    private List<string> uniqueCategories = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private string searchTerm = string.Empty;
    private string selectedCategory = string.Empty;
    private string selectedStatus = string.Empty;
    private bool showModal = false;
    private ServiceModel? selectedService = null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100);
            var token = await TokenStorage.GetTokenAsync();
            
            if (!string.IsNullOrEmpty(token))
            {
                ServiceService.SetToken(token);
                
                await LoadServices();
            }
            else
            {
                errorMessage = "Не удалось получить токен авторизации.";
                isLoading = false;
            }
            StateHasChanged();
        }
    }

    private async Task LoadServices()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            // Загружаем услуги через API
            allServices = await ServiceService.GetAllAsync();
            
            if (allServices == null)
            {
                allServices = new List<ServiceModel>();
            }
            
            uniqueCategories = allServices
                .Select(s => s.Category)
                .Where(c => !string.IsNullOrEmpty(c))
                .Distinct()
                .ToList();
            
            FilterServices();
        }
        catch (UnauthorizedAccessException)
        {
            errorMessage = "Недостаточно прав для просмотра услуг";
            allServices = new List<ServiceModel>();
            FilterServices();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка загрузки услуг: {ex.Message}";
            Console.WriteLine($"[AllServices] LoadServices error: {ex}");
            allServices = new List<ServiceModel>();
            FilterServices();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FilterServices()
    {
        if (allServices == null)
        {
            filteredServices = new List<ServiceModel>();
            return;
        }

        filteredServices = allServices.Where(s =>
            (string.IsNullOrEmpty(searchTerm) ||
             (s.Name != null && s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
             (s.Description != null && s.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
             (!string.IsNullOrEmpty(s.Category) && s.Category.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))) &&
            (string.IsNullOrEmpty(selectedCategory) || s.Category == selectedCategory) &&
            (string.IsNullOrEmpty(selectedStatus) || 
             (selectedStatus == "active" && s.IsActive) ||
             (selectedStatus == "inactive" && !s.IsActive))
        ).ToList();
    }

    private void OnCategoryFilterChanged(ChangeEventArgs e)
    {
        selectedCategory = e.Value?.ToString() ?? string.Empty;
        FilterServices();
    }

    private void OnStatusFilterChanged(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString() ?? string.Empty;
        FilterServices();
    }

    private void ResetFilters()
    {
        searchTerm = string.Empty;
        selectedCategory = string.Empty;
        selectedStatus = string.Empty;
        FilterServices();
    }

    private void ViewService(ServiceModel service)
    {
        selectedService = service;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedService = null;
    }
}

