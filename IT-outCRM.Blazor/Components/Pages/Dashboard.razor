                    </button>
                    <button class="action-btn" style="border-left: 4px solid #6f42c1;" @onclick='() => Navigation.NavigateTo("/my-deals")'>
                        <div class="action-icon" style="background: rgba(111,66,193,0.12);"><i class="bi bi-cash-stack" style="color: #6f42c1;"></i></div>
                        <div class="action-content">
                            <span class="action-title">Мои сделки</span>
                            <span class="action-desc">@activeDeals активных, @completedDeals завершённых</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                    <button class="action-btn action-success" @onclick='() => Navigation.NavigateTo("/my-services")'>
                        <div class="action-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <div class="action-content">
                            <span class="action-title">Мои услуги</span>
                            <span class="action-desc">Управление услугами</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                    <button class="action-btn action-info" @onclick='() => Navigation.NavigateTo("/orders")'>
                        <div class="action-icon"><i class="bi bi-search"></i></div>
                        <div class="action-content">
                            <span class="action-title">Все заказы</span>
                            <span class="action-desc">Найти новые заказы</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                    <button class="action-btn action-secondary" @onclick='() => Navigation.NavigateTo("/profile")'>
                        <div class="action-icon"><i class="bi bi-person-gear"></i></div>
                        <div class="action-content">
                            <span class="action-title">Мой профиль</span>
                            <span class="action-desc">Настройки аккаунта</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                </div>
            </div>

            @if (myOrders.Any())
            {
                <div class="recent-orders-card">
                    <div class="card-header-section">
                        <h3 class="card-title"><i class="bi bi-briefcase"></i> Текущие заказы</h3>
                        <a href="/executor/my-orders" class="view-all-link">Все заказы <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="order-cards-grid">
                        @foreach (var order in myOrders.Take(6))
                        {
                            <div class="order-card" @onclick='() => Navigation.NavigateTo($"/orders/{order.Id}")'>
                                <div class="order-card-header">
                                    <span class="status-badge @GetStatusClass(order.OrderStatusName)">@(string.IsNullOrEmpty(order.OrderStatusName) ? "—" : order.OrderStatusName)</span>
                                    <span class="price-value">@order.Price.ToString("N0", RuCulture)&nbsp;₽</span>
                                </div>
                                <h4 class="order-card-title">@order.Name</h4>
                                <div class="order-card-meta">
                                    <span><i class="bi bi-person"></i> @(string.IsNullOrEmpty(order.CustomerName) ? "—" : order.CustomerName)</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state-card">
                    <i class="bi bi-briefcase"></i>
                    <h3>Нет заказов в работе</h3>
                    <p>Посмотрите доступные заказы и возьмите в работу</p>
                    <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/orders")'>
                        <i class="bi bi-search"></i> Найти заказы
                    </button>
                </div>
            }

            @if (myServices.Any())
            {
                <div class="recent-orders-card" style="margin-top: 30px;">
                    <div class="card-header-section">
                        <h3 class="card-title"><i class="bi bi-grid-3x3-gap"></i> Мои услуги</h3>
                        <a href="/my-services" class="view-all-link">Управление <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="services-grid">
                        @foreach (var svc in myServices.Take(4))
                        {
                            <div class="service-mini-card">
                                <div class="service-mini-header">
                                    <span class="service-mini-name">@svc.Name</span>
                                    @if (svc.IsActive)
                                    {
                                        <span class="status-badge status-active">Активна</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-inactive">Неактивна</span>
                                    }
                                </div>
                                <div class="service-mini-footer">
                                    <span class="price-value">@svc.Price.ToString("N0", RuCulture)&nbsp;₽</span>
                                    <span class="service-duration"><i class="bi bi-clock"></i> @svc.Duration ч.</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </text>;
}

