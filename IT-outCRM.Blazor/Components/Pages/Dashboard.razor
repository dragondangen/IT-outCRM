@code {
    private bool isLoading = true;
    private string userRole = "";

    // Admin/Manager data
    private int totalOrders = 0;
    private int totalCustomers = 0;
    private int activeOrders = 0;
    private decimal totalRevenue = 0;
    private List<OrderModel> recentOrders = new();
    private List<AccountModel> allAccounts = new();
    private List<ExecutorModel> allExecutors = new();
    private List<CompanyModel> allCompanies = new();
    private List<ContactPersonModel> allContacts = new();
    private List<ServiceModel> allServices = new();
    private List<CustomerModel> allCustomersList = new();

    // Customer & Executor data
    private List<OrderModel> myOrders = new();
    private int myActiveOrders = 0;
    private int myCompletedOrders = 0;
    private List<ServiceModel> myServices = new();
    private ProfileInfo? myProfileInfo;

    // Deal data
    private List<DealModel> myDeals = new();
    private int activeDeals = 0;
    private int completedDeals = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Task.Delay(300);

        string? token = null;
        for (int i = 0; i < 3; i++)
        {
            token = await TokenStorage.GetTokenAsync();
            if (!string.IsNullOrEmpty(token)) break;
            await Task.Delay(500);
        }

        if (string.IsNullOrEmpty(token))
        {
            try { Navigation.NavigateTo("/login", forceLoad: true); }
            catch { }
            return;
        }

        try
        {
            // Determine role from token claims
            var handler = new System.IdentityModel.Tokens.Jwt.JwtSecurityTokenHandler();
            var jwtToken = handler.ReadJwtToken(token);
            var roleClaim = jwtToken.Claims.FirstOrDefault(c =>
                c.Type == System.Security.Claims.ClaimTypes.Role ||
                c.Type == "role" ||
                c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role");
            userRole = roleClaim?.Value ?? "";

            if (userRole == "Admin" || userRole == "Manager")
            {
                await LoadAdminData(token);
            }
            else if (userRole == "Executor")
            {
                await LoadExecutorData(token);
            }
            else
            {
                await LoadCustomerData(token);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dashboard data");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadAdminData(string token)
    {
        OrderService.SetToken(token);
        CustomerService.SetToken(token);
        ExecutorService.SetToken(token);
        ServiceService.SetToken(token);
        AccountService.SetToken(token);
        CompanyService.SetToken(token);
        ContactPersonService.SetToken(token);

        var orders = await OrderService.GetAllAsync();
        allCustomersList = await CustomerService.GetAllAsync();
        try { allExecutors = await ExecutorService.GetAllAsync(); } catch { }
        try { allServices = await ServiceService.GetAllAsync(); } catch { }
        try { allAccounts = await AccountService.GetAllAsync(); } catch { }
        try { allCompanies = await CompanyService.GetAllAsync(); } catch { }
        try { allContacts = await ContactPersonService.GetAllAsync(); } catch { }

        totalOrders = orders.Count;
        totalCustomers = allCustomersList.Count;
        totalRevenue = orders.Sum(o => o.Price);

        activeOrders = orders.Count(o =>
            !string.IsNullOrEmpty(o.OrderStatusName) &&
            !IsCompletedStatus(o.OrderStatusName));

        recentOrders = orders.OrderByDescending(o => o.Id).ToList();
    }

    private async Task LoadExecutorData(string token)
    {
        OrderService.SetToken(token);
        ServiceService.SetToken(token);
        ProfileService.SetToken(token);
        DealServiceDash.SetToken(token);

        try { myOrders = await OrderService.GetMyOrdersAsync(); } catch { myOrders = new(); }
        try { myServices = await ServiceService.GetMyServicesAsync(); } catch { myServices = new(); }
        try { myProfileInfo = await ProfileService.GetMyInfoAsync(); } catch { }
        try { myDeals = await DealServiceDash.GetMyDealsAsync(); } catch { myDeals = new(); }

        myActiveOrders = myOrders.Count(o => !IsCompletedStatus(o.OrderStatusName ?? ""));
        myCompletedOrders = myOrders.Count(o => IsCompletedStatus(o.OrderStatusName ?? ""));
        activeDeals = myDeals.Count(d => d.Status != "Завершена" && d.Status != "Отменена");
        completedDeals = myDeals.Count(d => d.Status == "Завершена");
    }

    private async Task LoadCustomerData(string token)
    {
        OrderService.SetToken(token);
        ProfileService.SetToken(token);
        DealServiceDash.SetToken(token);

        try { myOrders = await OrderService.GetMyOrdersAsync(); } catch { myOrders = new(); }
        try { myProfileInfo = await ProfileService.GetMyInfoAsync(); } catch { }
        try { myDeals = await DealServiceDash.GetMyDealsAsync(); } catch { myDeals = new(); }

        myActiveOrders = myOrders.Count(o => !IsCompletedStatus(o.OrderStatusName ?? ""));
        myCompletedOrders = myOrders.Count(o => IsCompletedStatus(o.OrderStatusName ?? ""));
        activeDeals = myDeals.Count(d => d.Status != "Завершена" && d.Status != "Отменена");
        completedDeals = myDeals.Count(d => d.Status == "Завершена");
    }

    private bool IsCompletedStatus(string status) =>
        status.Contains("завершен", StringComparison.OrdinalIgnoreCase) ||
        status.Contains("закрыт", StringComparison.OrdinalIgnoreCase) ||
        status.Contains("выполнен", StringComparison.OrdinalIgnoreCase) ||
        status.Contains("completed", StringComparison.OrdinalIgnoreCase) ||
        status.Contains("closed", StringComparison.OrdinalIgnoreCase);

    private static readonly System.Globalization.CultureInfo RuCulture = System.Globalization.CultureInfo.GetCultureInfo("ru-RU");

    private string FormatMoney(decimal amount)
    {
        if (amount >= 1_000_000)
            return $"{(amount / 1_000_000):N1} млн ₽".Replace(",0 ", " ");
        return $"{amount.ToString("N0", RuCulture)}\u00A0₽";
    }

    private string GetStatusClass(string? status)
    {
        if (string.IsNullOrEmpty(status)) return "status-primary";
        var s = status.ToLower();
        if (s.Contains("новый") || s.Contains("new")) return "status-new";
        if (s.Contains("работ") || s.Contains("progress")) return "status-progress";
        if (s.Contains("завершен") || s.Contains("выполнен") || s.Contains("completed") || s.Contains("closed")) return "status-done";
        if (s.Contains("отменен") || s.Contains("cancel")) return "status-cancelled";
        return "status-active";
    }

    private string GetRoleDisplayName(string role) => role switch
    {
        "Admin" => "Администратор",
        "Manager" => "Менеджер",
        "Executor" => "Исполнитель",
        "User" => "Клиент",
        "Customer" => "Заказчик",
        _ => role
    };

    [Inject] private IServiceProvider ServiceProvider { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = default!;
}
