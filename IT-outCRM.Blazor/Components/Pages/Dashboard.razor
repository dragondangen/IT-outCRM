@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using IT_outCRM.Blazor.Services
@using IT_outCRM.Blazor.Models
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IOrderService OrderService
@inject ICustomerService CustomerService
@inject IServiceService ServiceService
@inject IExecutorService ExecutorService
@inject IAccountService AccountService
@inject ICompanyService CompanyService
@inject IContactPersonService ContactPersonService
@inject IOrderStatusService OrderStatusService
@inject ITokenStorage TokenStorage
@inject IProfileService ProfileService
@inject IDealService DealServiceDash
@inject NavigationManager Navigation
@inject ILogger<Dashboard> Logger

<PageTitle>Панель управления - IT-outCRM</PageTitle>

<AuthorizeView>
    <Authorized Context="authContext">
        <div class="dashboard-container">
            <div class="welcome-hero">
                <div class="welcome-content">
                    <h1 class="welcome-title">
                        <i class="bi bi-graph-up-arrow"></i> Панель управления
                    </h1>
                    <p class="welcome-subtitle">
                        Добро пожаловать, <strong>@authContext.User.Identity?.Name</strong>!
                    </p>
                    <p class="welcome-date">
                        <i class="bi bi-calendar-event"></i> @DateTime.Now.ToString("dddd, dd MMMM yyyy")
                    </p>
                    @if (!string.IsNullOrEmpty(userRole))
                    {
                        <span class="role-badge">@GetRoleDisplayName(userRole)</span>
                    }
                </div>
                <div class="welcome-decoration">
                    @if (userRole == "Admin" || userRole == "Manager")
                    {
                        <i class="bi bi-speedometer2"></i>
                    }
                    else if (userRole == "Executor")
                    {
                        <i class="bi bi-briefcase-fill"></i>
                    }
                    else
                    {
                        <i class="bi bi-bag-check-fill"></i>
                    }
                </div>
            </div>

            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <p>Загрузка данных...</p>
                </div>
            }
            else if (userRole == "Admin" || userRole == "Manager")
            {
                @RenderAdminDashboard()
            }
            else if (userRole == "Executor")
            {
                @RenderExecutorDashboard()
            }
            else
            {
                @RenderCustomerDashboard()
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@* ==================== ADMIN / MANAGER DASHBOARD ==================== *@
@{
    RenderFragment RenderAdminDashboard() =>
        @<text>
            <div class="stats-grid stats-grid-6">
                <div class="stat-card stat-card-primary">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-box-seam stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Заказы</p>
                            <p class="stat-number">@totalOrders</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><a href="/orders" class="stat-link">Все <i class="bi bi-arrow-right"></i></a></div>
                </div>
                <div class="stat-card stat-card-success">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-people-fill stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Клиенты</p>
                            <p class="stat-number">@totalCustomers</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><a href="/customers" class="stat-link">Все <i class="bi bi-arrow-right"></i></a></div>
                </div>
                <div class="stat-card stat-card-warning">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-person-workspace stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Исполнители</p>
                            <p class="stat-number">@allExecutors.Count</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><a href="/executors" class="stat-link">Все <i class="bi bi-arrow-right"></i></a></div>
                </div>
                <div class="stat-card stat-card-info">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-building stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Компании</p>
                            <p class="stat-number">@allCompanies.Count</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><a href="/companies" class="stat-link">Все <i class="bi bi-arrow-right"></i></a></div>
                </div>
                <div class="stat-card stat-card-primary">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-grid-3x3-gap-fill stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Услуги</p>
                            <p class="stat-number">@allServices.Count</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><a href="/services" class="stat-link">Все <i class="bi bi-arrow-right"></i></a></div>
                </div>
                <div class="stat-card stat-card-info">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-currency-exchange stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Оборот</p>
                            <p class="stat-number stat-number-sm">@FormatMoney(totalRevenue)</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><span class="stat-badge success">Выручка</span></div>
                </div>
            </div>

            @* --- Аккаунты с привязками --- *@
            @if (allAccounts.Any())
            {
                <div class="recent-orders-card" style="margin-bottom:30px;">
                    <div class="card-header-section">
                        <h3 class="card-title"><i class="bi bi-diagram-3"></i> Аккаунты и привязки</h3>
                        <a href="/accounts" class="view-all-link">Все аккаунты <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="orders-table-wrapper">
                        <table class="orders-table">
                            <thead>
                                <tr>
                                    <th>Компания</th>
                                    <th>Статус</th>
                                    <th>Клиенты</th>
                                    <th>Исполнители</th>
                                    <th>Заказы</th>
                                    <th>Услуги</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var acc in allAccounts)
                                {
                                    var accCustomers = allCustomersList.Where(c => c.AccountId == acc.Id).ToList();
                                    var accExecutors = allExecutors.Where(e => e.AccountId == acc.Id).ToList();
                                    var accCustomerIds = accCustomers.Select(c => c.Id).ToHashSet();
                                    var accExecutorIds = accExecutors.Select(e => e.Id).ToHashSet();
                                    var accOrders = recentOrders.Count(o => accCustomerIds.Contains(o.CustomerId) || (o.ExecutorId.HasValue && accExecutorIds.Contains(o.ExecutorId.Value)));
                                    var accServices = allServices.Count(s => accExecutorIds.Contains(s.ExecutorId));
                                    <tr>
                                        <td><strong>@acc.CompanyName</strong></td>
                                        <td><span class="status-badge @(acc.AccountStatusName == "Активный" ? "status-done" : "status-active")">@acc.AccountStatusName</span></td>
                                        <td>@accCustomers.Count</td>
                                        <td>@accExecutors.Count</td>
                                        <td>@accOrders</td>
                                        <td>@accServices</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* --- Последние заказы --- *@
            @if (recentOrders.Any())
            {
                <div class="recent-orders-card" style="margin-bottom:30px;">
                    <div class="card-header-section">
                        <h3 class="card-title"><i class="bi bi-clock-history"></i> Все заказы</h3>
                        <a href="/orders" class="view-all-link">Посмотреть все <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="orders-table-wrapper">
                        <table class="orders-table">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Клиент</th>
                                    <th>Цена</th>
                                    <th>Исполнитель</th>
                                    <th>Статус</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in recentOrders.Take(10))
                                {
                                    <tr>
                                        <td><div class="order-name-cell"><i class="bi bi-file-earmark-text"></i> <strong>@order.Name</strong></div></td>
                                        <td>@(string.IsNullOrEmpty(order.CustomerName) ? "—" : order.CustomerName)</td>
                                        <td><span class="price-value">@order.Price.ToString("N0", RuCulture)&nbsp;₽</span></td>
                                        <td>@(string.IsNullOrEmpty(order.ExecutorName) ? "—" : order.ExecutorName)</td>
                                        <td><span class="status-badge @GetStatusClass(order.OrderStatusName)">@(string.IsNullOrEmpty(order.OrderStatusName) ? "—" : order.OrderStatusName)</span></td>
                                        <td><button class="table-action-btn" @onclick='() => Navigation.NavigateTo($"/orders/{order.Id}")'><i class="bi bi-eye"></i></button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* --- Контактные лица --- *@
            @if (allContacts.Any())
            {
                <div class="recent-orders-card" style="margin-bottom:30px;">
                    <div class="card-header-section">
                        <h3 class="card-title"><i class="bi bi-person-lines-fill"></i> Контактные лица</h3>
                    </div>
                    <div class="orders-table-wrapper">
                        <table class="orders-table">
                            <thead><tr><th>ФИО</th><th>Email</th><th>Телефон</th><th>Роль</th></tr></thead>
                            <tbody>
                                @foreach (var cp in allContacts.Take(10))
                                {
                                    <tr>
                                        <td><strong>@(string.IsNullOrEmpty(cp.FullName) ? $"{cp.LastName} {cp.FirstName}" : cp.FullName)</strong></td>
                                        <td>@cp.Email</td>
                                        <td>@cp.PhoneNumber</td>
                                        <td>@cp.Role</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* --- Услуги --- *@
            @if (allServices.Any())
            {
                <div class="recent-orders-card">
                    <div class="card-header-section">
                        <h3 class="card-title"><i class="bi bi-grid-3x3-gap"></i> Услуги</h3>
                        <a href="/services" class="view-all-link">Все услуги <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="orders-table-wrapper">
                        <table class="orders-table">
                            <thead><tr><th>Название</th><th>Исполнитель</th><th>Цена</th><th>Длит.</th><th>Статус</th></tr></thead>
                            <tbody>
                                @foreach (var svc in allServices.Take(10))
                                {
                                    <tr>
                                        <td><strong>@svc.Name</strong></td>
                                        <td>@svc.ExecutorName</td>
                                        <td><span class="price-value">@svc.Price.ToString("N0", RuCulture)&nbsp;₽</span></td>
                                        <td>@svc.Duration ч.</td>
                                        <td><span class="status-badge @(svc.IsActive ? "status-done" : "status-inactive")">@(svc.IsActive ? "Активна" : "Неактивна")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </text>;
}

@* ==================== CUSTOMER / USER DASHBOARD ==================== *@
@{
    RenderFragment RenderCustomerDashboard() =>
        @<text>
            @if (myProfileInfo != null && !string.IsNullOrEmpty(myProfileInfo.CompanyName))
            {
                <div class="company-info-banner">
                    <div class="company-info-content">
                        <i class="bi bi-building"></i>
                        <div>
                            <strong>@myProfileInfo.CompanyName</strong>
                            @if (!string.IsNullOrEmpty(myProfileInfo.AccountName))
                            {
                                <span class="company-info-sep">•</span>
                                <span>Аккаунт: @myProfileInfo.AccountName</span>
                            }
                            @if (!string.IsNullOrEmpty(myProfileInfo.AccountStatus))
                            {
                                <span class="account-status-badge @(myProfileInfo.AccountStatus == "Активный" ? "active" : "")">@myProfileInfo.AccountStatus</span>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="stats-grid">
                <div class="stat-card stat-card-primary">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-box-seam stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Мои заказы</p>
                            <p class="stat-number">@myOrders.Count</p>
                        </div>
                    </div>
                    <div class="stat-card-footer">
                        <a href="/my-orders" class="stat-link">Посмотреть <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                <div class="stat-card stat-card-warning">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-hourglass-split stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">В работе</p>
                            <p class="stat-number">@myActiveOrders</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><span class="stat-badge">Активных</span></div>
                </div>

                <div class="stat-card stat-card-success">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-check-circle-fill stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Завершено</p>
                            <p class="stat-number">@myCompletedOrders</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><span class="stat-badge success">Готово</span></div>
                </div>

                <div class="stat-card stat-card-info">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper"><i class="bi bi-wallet2 stat-icon"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Сумма заказов</p>
                            <p class="stat-number stat-number-sm">@FormatMoney(myOrders.Sum(o => o.Price))</p>
                        </div>
                    </div>
                    <div class="stat-card-footer"><span class="stat-badge">Общая</span></div>
                </div>

                <div class="stat-card" style="border-top: 4px solid #6f42c1;">
                    <div class="stat-card-inner">
                        <div class="stat-icon-wrapper" style="background: rgba(111,66,193,0.12);"><i class="bi bi-cash-stack stat-icon" style="color: #6f42c1;"></i></div>
                        <div class="stat-content">
                            <p class="stat-label">Сделки</p>
                            <p class="stat-number">@myDeals.Count</p>
                        </div>
                    </div>
                    <div class="stat-card-footer">
                        <a href="/my-deals" class="stat-link">Посмотреть <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <div class="quick-actions-card">
                <div class="card-header-section">
                    <h3 class="card-title"><i class="bi bi-lightning-charge"></i> Быстрые действия</h3>
                </div>
                <div class="actions-grid">
                    <button class="action-btn action-primary" @onclick='() => Navigation.NavigateTo("/my-orders")'>
                        <div class="action-icon"><i class="bi bi-list-check"></i></div>
                        <div class="action-content">
                            <span class="action-title">Мои заказы</span>
                            <span class="action-desc">Просмотр и отслеживание</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                    <button class="action-btn" style="border-left: 4px solid #6f42c1;" @onclick='() => Navigation.NavigateTo("/my-deals")'>
                        <div class="action-icon" style="background: rgba(111,66,193,0.12);"><i class="bi bi-cash-stack" style="color: #6f42c1;"></i></div>
                        <div class="action-content">
                            <span class="action-title">Мои сделки</span>
                            <span class="action-desc">@activeDeals активных, @completedDeals завершённых</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                    <button class="action-btn action-success" @onclick='() => Navigation.NavigateTo("/services-catalog")'>
                        <div class="action-icon"><i class="bi bi-shop"></i></div>
                        <div class="action-content">
                            <span class="action-title">Каталог услуг</span>
                            <span class="action-desc">Заказать услуги исполнителей</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                    <button class="action-btn action-info" @onclick='() => Navigation.NavigateTo("/profile")'>
                        <div class="action-icon"><i class="bi bi-person-gear"></i></div>
                        <div class="action-content">
                            <span class="action-title">Мой профиль</span>
                            <span class="action-desc">Компания и настройки</span>
                        </div>
                        <i class="bi bi-chevron-right action-arrow"></i>
                    </button>
                </div>
            </div>

            @if (myOrders.Any())
            {
                <div class="recent-orders-card">
                    <div class="card-header-section">
                        <h3 class="card-title"><i class="bi bi-clock-history"></i> Мои последние заказы</h3>
                        <a href="/my-orders" class="view-all-link">Все заказы <i class="bi bi-arrow-right"></i></a>
                    </div>
                    <div class="order-cards-grid">
                        @foreach (var order in myOrders.Take(6))
                        {
                            <div class="order-card" @onclick='() => Navigation.NavigateTo($"/orders/{order.Id}")'>
                                <div class="order-card-header">
                                    <span class="status-badge @GetStatusClass(order.OrderStatusName)">@(string.IsNullOrEmpty(order.OrderStatusName) ? "—" : order.OrderStatusName)</span>
                                    <span class="price-value">@order.Price.ToString("N0", RuCulture)&nbsp;₽</span>
                                </div>
                                <h4 class="order-card-title">@order.Name</h4>
                                <div class="order-card-meta">
                                    <span><i class="bi bi-person-badge"></i> @(string.IsNullOrEmpty(order.ExecutorName) ? "Не назначен" : order.ExecutorName)</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state-card">
                    <i class="bi bi-inbox"></i>
                    <h3>У вас пока нет заказов</h3>
                    <p>Ваши заказы появятся здесь</p>
                </div>
            }
        </text>;
}

