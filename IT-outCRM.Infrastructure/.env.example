# ===========================================
# Docker Compose Environment Variables
# ===========================================
# 
# ИНСТРУКЦИЯ:
# 1. Скопируйте этот файл и переименуйте в .env
# 2. Замените значения по умолчанию на свои реальные пароли
# 3. НЕ КОММИТЬТЕ .env файл в Git!
#
# Команда для копирования:
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env
# ===========================================

# PostgreSQL Database Configuration
# Используется для контейнера postgres
POSTGRES_DB=mydb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# pgAdmin Configuration
# Используется для контейнера pgadmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ===========================================
# ВАЖНО:
# - Используйте сильные пароли (мин. 12 символов)
# - Разные пароли для каждого сервиса
# - Никогда не используйте эти примеры в production
# ===========================================
